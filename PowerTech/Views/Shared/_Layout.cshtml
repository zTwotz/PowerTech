<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PowerTech</title>
    
    <!-- Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Icons - FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PowerTech.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="/images/logo_web.png">
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    <div class="header-wrapper">
        <!-- Main Red Header -->
        <header class="main-header py-2" style="background-color: #e30019;">
            <div class="container d-flex align-items-center gap-3">
                <!-- Logo -->
                <a class="logo d-flex align-items-center justify-content-center overflow-hidden" asp-area="Store" asp-controller="Home" asp-action="Index" style="width: 160px; height: 50px;">
                    <img src="/images/logo.png" alt="PowerTech Logo" style="width: 120%; height: 120%; object-fit: contain; filter: brightness(0) invert(1); margin: -10% 0;" />
                </a>

                <!-- Category Toggle Button -->
                <a asp-area="Store" asp-controller="Product" asp-action="Index" class="header-category-btn d-flex align-items-center gap-2 px-3 py-2 rounded text-white text-decoration-none cursor-pointer flex-shrink-0" style="background: rgba(0,0,0,0.15); border: 1px solid rgba(255,255,255,0.1); font-size: 14px; min-width: fit-content; margin-left: -10px;">
                    <i class="fa-solid fa-bars fs-5"></i>
                    <span class="fw-bold">Danh mục</span>
                </a>

                <!-- Search Bar -->
                <div class="search-wrap flex-grow-1 position-relative">
                    <form asp-area="Store" asp-controller="Product" asp-action="Index" method="get" class="m-0">
                        <input type="text" name="q" value="@ViewContext.HttpContext.Request.Query["q"]" placeholder="Bạn cần tìm gì?" class="form-control border-0 shadow-none ps-3 pe-5" style="height: 40px; font-size: 13px; border-radius: 4px;" />
                        <button type="submit" class="btn position-absolute top-50 end-0 translate-middle-y bg-transparent" style="margin-right: 5px;"><i class="fa-solid fa-magnifying-glass text-dark"></i></button>
                    </form>
                </div>

                <!-- Right Actions -->
                <div class="header-actions d-flex align-items-center gap-3 text-white">
                    <!-- Hotline -->
                    <a href="tel:19005301" class="header-action-item d-flex align-items-center gap-2 text-decoration-none text-white">
                        <i class="fa-solid fa-headset fs-4"></i>
                        <div class="d-flex flex-column text-start">
                            <span class="lh-1" style="font-size: 11px;">Hotline</span>
                            <strong class="lh-1" style="font-size: 13px;">1900.5301</strong>
                        </div>
                    </a>

                    <!-- Showroom -->
                    <a asp-area="Store" asp-controller="Home" asp-action="Showrooms" class="header-action-item d-flex align-items-center gap-2 text-decoration-none text-white d-none d-xl-flex">
                        <i class="fa-solid fa-location-dot fs-4"></i>
                        <div class="d-flex flex-column text-start">
                            <span class="lh-1" style="font-size: 11px;">Hệ thống</span>
                            <span class="lh-1 fw-bold" style="font-size: 13px;">Showroom</span>
                        </div>
                    </a>

                    <!-- Track Order -->
                    <a asp-area="Customer" asp-controller="Order" asp-action="Index" class="header-action-item d-flex align-items-center gap-2 text-decoration-none text-white d-none d-lg-flex">
                        <i class="fa-solid fa-clipboard-list fs-4"></i>
                        <div class="d-flex flex-column text-start">
                            <span class="lh-1" style="font-size: 11px;">Tra cứu</span>
                            <span class="lh-1 fw-bold" style="font-size: 13px;">đơn hàng</span>
                        </div>
                    </a>

@inject PowerTech.Services.Interfaces.ICartService CartService
@inject Microsoft.AspNetCore.Identity.UserManager<PowerTech.Models.Entities.ApplicationUser> UserManager
@{
    // Ưu tiên lấy từ Cookie để đạt tốc độ hiển thị tối đa (không chớp)
    var cartCountStr = Context.Request.Cookies["PT_CartCount"];
    int initialCartCount = 0;
    
    if (!string.IsNullOrEmpty(cartCountStr) && int.TryParse(cartCountStr, out int c))
    {
        initialCartCount = c;
    }
    else
    {
        // Fallback nếu chưa có cookie (lần đầu truy cập)
        var userId = UserManager.GetUserId(User);
        var guestId = Context.Request.Cookies["PT_GuestCartId"];
        var ownerId = userId ?? guestId;
        if (!string.IsNullOrEmpty(ownerId))
        {
            initialCartCount = CartService.GetCartItemCountAsync(ownerId).GetAwaiter().GetResult();
        }
    }
}
<a asp-area="Store" asp-controller="Cart" asp-action="Index" class="header-action-item d-flex align-items-center gap-2 text-decoration-none text-white">
    <div class="position-relative">
        <i class="fa-solid fa-cart-shopping fs-4"></i>
        <span class="badge position-absolute top-0 start-100 translate-middle bg-warning text-dark border border-white rounded-circle fw-bold cart-count" id="headerCartCount" style="font-size: 10px; padding: 2px 5px;">@initialCartCount</span>
        <script>
            // Script bảo hiểm - chạy ngay lập tức khi trình duyệt đọc đến đây
            (function() {
                var c = ("; "+document.cookie).split("; PT_CartCount=").pop().split(";").shift();
                if(c !== "") document.getElementById('headerCartCount').innerText = c;
            })();
        </script>
    </div>
    <div class="d-flex flex-column text-start d-none d-sm-flex">
        <span class="lh-1" style="font-size: 11px;">Giỏ</span>
        <span class="lh-1 fw-bold" style="font-size: 13px;">hàng</span>
    </div>
</a>

                    <!-- User Account / Login -->
                    <div class="user-action ps-2">
                        @using PowerTech.Constants
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
