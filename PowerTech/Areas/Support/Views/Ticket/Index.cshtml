@model IEnumerable<PowerTech.Models.Entities.SupportTicket>
@{
    Layout = "_SupportLayout";
    ViewData["Title"] = "Quản lý Ticket hỗ trợ";
}

<div class="row g-4 mb-4">
    <div class="col-md-6 text-start">
        <h4 class="fw-bold mb-1 text-dark">Tickets Hỗ trợ</h4>
        <p class="text-muted small">Quản lý và giải quyết các yêu cầu hỗ trợ kỹ thuật, bảo hành từ khách hàng</p>
    </div>
    <div class="col-md-6 text-md-end pt-2">
        <div class="btn-group rounded-pill overflow-hidden border shadow-sm me-2 bg-white">
            <a asp-action="Index" asp-route-status="" class="btn btn-sm btn-@(string.IsNullOrEmpty(ViewBag.CurrentStatus) ? "info text-white" : "outline-secondary border-0") px-3">Tất cả</a>
            <a asp-action="Index" asp-route-status="Open" class="btn btn-sm btn-@(ViewBag.CurrentStatus == "Open" ? "info text-white" : "outline-secondary border-0") px-3">Mới</a>
            <a asp-action="Index" asp-route-status="In Progress" class="btn btn-sm btn-@(ViewBag.CurrentStatus == "In Progress" ? "info text-white" : "outline-secondary border-0") px-3">Đang xử lý</a>
        </div>
        <div class="btn-group rounded-pill overflow-hidden border shadow-sm bg-white">
            <a asp-action="Index" asp-route-priority="High" class="btn btn-sm btn-outline-danger border-0 px-3">Ưu tiên cao 🔥</a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Mã số</th>
                        <th>Thông tin khách hàng</th>
                        <th>Tiêu đề</th>
                        <th class="text-center">Mức độ</th>
                        <th class="text-center">Trạng thái</th>
                        <th>Người xử lý</th>
                        <th class="pe-4 text-end">Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-primary">@ticket.TicketCode</td>
                            <td>
                                <div class="fw-bold small">@ticket.User?.FullName</div>
                                <div class="text-muted x-small">@ticket.User?.Email</div>
                            </td>
                            <td class="text-truncate fw-medium" style="max-width: 200px;" title="@ticket.Title">@ticket.Title</td>
                            <td class="text-center">
                                <span class="badge @(ticket.Priority switch {
                                    "High" => "bg-danger",
                                    "Medium" => "bg-warning text-dark",
                                    _ => "bg-info text-white"
                                }) border shadow-sm rounded-pill px-3">@ticket.Priority</span>
                            </td>
                            <td class="text-center">
                                <span class="badge @(ticket.Status switch {
                                    "Open" => "bg-dark",
                                    "In Progress" => "bg-primary text-white",
                                    "Closed" => "bg-success",
                                    _ => "bg-secondary"
                                }) rounded-pill px-3">@ticket.Status</span>
                            </td>
                            <td>
                                @if (ticket.AssignedTo != null)
                                {
                                    <div class="d-flex align-items-center">
                                        <img src="https://ui-avatars.com/api/?name=@ticket.AssignedTo.FullName&background=eee" class="rounded-circle me-1 border" style="width: 20px;" />
                                        <span class="x-small fw-bold">@ticket.AssignedTo.FullName</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="x-small text-muted italic">Chưa phân công</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-outline-info btn-sm rounded-pill px-3 shadow-sm">
                                    Xử lý
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">Không tìm thấy Ticket nào cần xử lý</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 11px; }
    .italic { font-style: italic; }
</style>
