@model PowerTech.Models.Entities.Coupon
@{
    ViewData["Title"] = "Thêm mã giảm giá mới";
    Layout = "_SalesLayout";
}

<div class="row mb-4 pb-2">
    <div class="col-12">
        <a asp-action="Index" class="btn btn-link text-muted p-0 text-decoration-none mb-2">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
        <h3 class="fw-800 text-dark">Thêm mã giảm giá mới</h3>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="card-header bg-white p-4 border-0 pb-0">
                <h5 class="fw-800 text-dark mb-0"><i class="bi bi-info-circle-fill text-primary me-2"></i>Thông tin cơ bản</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="Code" class="form-label fw-bold small text-muted text-uppercase">Mã giảm giá</label>
                            <input asp-for="Code" class="form-control border-0 bg-light rounded-3 py-2 px-3 fw-bold text-primary" placeholder="Vd: GIAM10, TET2024..." style="text-transform: uppercase;">
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Type" class="form-label fw-bold small text-muted text-uppercase">Loại giảm giá</label>
                            <select asp-for="Type" class="form-select border-0 bg-light rounded-3 py-2 px-3" asp-items="Html.GetEnumSelectList<PowerTech.Models.Entities.CouponType>()"></select>
                            <span asp-validation-for="Type" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Value" class="form-label fw-bold small text-muted text-uppercase">Giá trị giảm</label>
                            <div class="input-group">
                                <input asp-for="Value" type="number" step="0.01" class="form-control border-0 bg-light rounded-3 py-2 px-3 fw-bold" placeholder="0.00">
                                <span class="input-group-text border-0 bg-light" id="value-unit">%</span>
                            </div>
                            <span asp-validation-for="Value" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6" id="max-discount-container">
                            <label asp-for="MaxDiscountAmount" class="form-label fw-bold small text-muted text-uppercase">Số tiền giảm tối đa (₫)</label>
                            <input asp-for="MaxDiscountAmount" type="number" step="1000" class="form-control border-0 bg-light rounded-3 py-2 px-3" placeholder="Để trống nếu không giới hạn">
                            <span asp-validation-for="MaxDiscountAmount" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <hr class="my-2 opacity-5">
                            <h5 class="fw-800 text-dark mb-3 mt-2"><i class="bi bi-shield-check text-success me-2"></i>Điều kiện & Giới hạn</h5>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="MinOrderValue" class="form-label fw-bold small text-muted text-uppercase">Đơn hàng tối thiểu (₫)</label>
                            <input asp-for="MinOrderValue" type="number" step="1000" class="form-control border-0 bg-light rounded-3 py-2 px-3" placeholder="0">
                            <span asp-validation-for="MinOrderValue" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UsageLimit" class="form-label fw-bold small text-muted text-uppercase">Số lượng mã (Tổng)</label>
                            <input asp-for="UsageLimit" type="number" class="form-control border-0 bg-light rounded-3 py-2 px-3" placeholder="Để trống nếu không giới hạn">
                            <span asp-validation-for="UsageLimit" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-bold small text-muted text-uppercase">Ngày bắt đầu</label>
                            <input asp-for="StartDate" type="date" class="form-control border-0 bg-light rounded-3 py-2 px-3">
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-bold small text-muted text-uppercase">Ngày kết thúc</label>
                            <input asp-for="EndDate" type="date" class="form-control border-0 bg-light rounded-3 py-2 px-3">
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>

                        <div class="col-12 py-3">
                            <div class="form-check form-switch p-3 bg-light rounded-4 border-dashed d-flex align-items-center justify-content-between">
                                <div class="ms-1">
                                    <label class="form-check-label fw-bold text-dark mb-0" for="IsActive">Kích hoạt ngay</label>
                                    <p class="text-muted small mb-0">Mã sẽ khả dụng ngay khi bạn lưu nếu điều kiện thời gian hợp lệ</p>
                                </div>
                                <input asp-for="IsActive" class="form-check-input me-3" style="width: 50px; height: 26px;">
                            </div>
                        </div>

                        <div class="col-12 text-center mt-3">
                            <button type="submit" class="btn btn-primary fw-800 rounded-pill px-5 py-3 shadow-lg border-0">
                                LƯU MÃ GIẢM GIÁ
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            function updateUI() {
                var type = $('#Type').val();
                if (type == '0') { // Percentage
                    $('#value-unit').text('%');
                    $('#max-discount-container').slideDown();
                } else { // FixedAmount
                    $('#value-unit').text('₫');
                    $('#max-discount-container').slideUp();
                }
            }

            $('#Type').change(updateUI);
            updateUI();

            $('input[name="Code"]').on('input', function() {
                $(this).val($(this).val().toUpperCase());
            });
        });
    </script>
}

@section Styles {
    <style>
        .border-dashed { border: 2px dashed #dee2e6; }
        .form-control:focus, .form-select:focus {
            box-shadow: none;
            background-color: #f1f5f9 !important;
            border: 1px solid var(--bs-primary) !important;
        }
        .input-group-text {
            border-top-right-radius: 12px !important;
            border-bottom-right-radius: 12px !important;
            font-weight: 800;
            color: #64748b;
        }
    </style>
}
