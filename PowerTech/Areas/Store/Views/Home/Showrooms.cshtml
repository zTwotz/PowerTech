@{
    ViewData["Title"] = "Hệ thống Showroom - PowerTech";
}

<div class="showroom-page pb-5">
    <!-- Hero Banner -->
    <div class="showroom-hero position-relative overflow-hidden mb-5" style="height: 400px;">
        <img src="/images/showrooms/showroom_hero.png" alt="PowerTech Showroom" class="w-100 h-100 object-fit-cover">
        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.7));">
            <div class="text-center text-white p-4">
                <h1 class="display-4 fw-800 text-uppercase mb-2 tracking-tight">Hệ thống Showroom</h1>
                <p class="lead opacity-90 mb-0">Trải nghiệm không gian công nghệ đỉnh cao và dịch vụ tận tâm</p>
                <div class="mt-4">
                    <span class="badge bg-danger px-3 py-2 fs-6 rounded-pill"><i class="fa-solid fa-clock me-2"></i>Mở cửa: 08:00 - 21:00 (hàng ngày)</span>
                </div>
            </div>
        </div>
    </div>

    <div class="container mt-n5">
        <div class="row g-4">
            <!-- Branch 1 -->
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm overflow-hidden hover-float showroom-card">
                    <div class="row g-0 h-100">
                        <div class="col-md-5">
                            <div class="h-100 overflow-hidden">
                                <img src="https://images.unsplash.com/photo-1591405351990-4726e331f141?q=80&w=1000&auto=format&fit=crop" class="w-100 h-100 object-fit-cover" alt="Showroom Điện Biên Phủ">
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="card-body p-4 d-flex flex-column h-100">
                                <div class="mb-auto">
                                    <h3 class="h5 fw-bold text-danger mb-3">Showroom Điện Biên Phủ</h3>
                                    <div class="d-flex gap-2 mb-3 align-items-start">
                                        <i class="fa-solid fa-location-dot text-muted mt-1"></i>
                                        <p class="small text-muted mb-0">475A Điện Biên Phủ, Phường 25, Thạnh Mỹ Tây, Hồ Chí Minh 70000, Việt Nam</p>
                                    </div>
                                    <div class="d-flex gap-2 mb-2 align-items-center">
                                        <i class="fa-solid fa-phone text-muted small"></i>
                                        <p class="small text-muted mb-0">Hotline: 1900.5301</p>
                                    </div>
                                </div>
                                <a href="https://maps.app.goo.gl/8SMxDqFEhMFz51QNA" target="_blank" class="btn btn-outline-danger w-100 mt-3 d-flex align-items-center justify-content-center gap-2">
                                    <i class="fa-solid fa-map-location-dot"></i>
                                    Xem trên Google Maps
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Branch 2 -->
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm overflow-hidden hover-float showroom-card">
                    <div class="row g-0 h-100">
                        <div class="col-md-5">
                            <div class="h-100 overflow-hidden">
                                <img src="https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=1000&auto=format&fit=crop" class="w-100 h-100 object-fit-cover" alt="Showroom Ung Văn Khiêm">
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="card-body p-4 d-flex flex-column h-100">
                                <div class="mb-auto">
                                    <h3 class="h5 fw-bold text-danger mb-3">Showroom Ung Văn Khiêm</h3>
                                    <div class="d-flex gap-2 mb-3 align-items-start">
                                        <i class="fa-solid fa-location-dot text-muted mt-1"></i>
                                        <p class="small text-muted mb-0">31/36 Đ. Ung Văn Khiêm, Phường Thạnh Mỹ Tây, Thạnh Mỹ Tây, Hồ Chí Minh, Việt Nam</p>
                                    </div>
                                    <div class="d-flex gap-2 mb-2 align-items-center">
                                        <i class="fa-solid fa-phone text-muted small"></i>
                                        <p class="small text-muted mb-0">Hotline: 1900.5301</p>
                                    </div>
                                </div>
                                <a href="https://maps.app.goo.gl/TegXmrXXWrwMcbjV8" target="_blank" class="btn btn-outline-danger w-100 mt-3 d-flex align-items-center justify-content-center gap-2">
                                    <i class="fa-solid fa-map-location-dot"></i>
                                    Xem trên Google Maps
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Branch 3 -->
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm overflow-hidden hover-float showroom-card">
                    <div class="row g-0 h-100">
                        <div class="col-md-5">
                            <div class="h-100 overflow-hidden">
                                <img src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=1000&auto=format&fit=crop" class="w-100 h-100 object-fit-cover" alt="Showroom Hiệp Phú">
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="card-body p-4 d-flex flex-column h-100">
                                <div class="mb-auto">
                                    <h3 class="h5 fw-bold text-danger mb-3">Showroom SHTP (Hiệp Phú)</h3>
                                    <div class="d-flex gap-2 mb-3 align-items-start">
                                        <i class="fa-solid fa-location-dot text-muted mt-1"></i>
                                        <p class="small text-muted mb-0">Khu Công nghệ cao XLHN, Hiệp Phú, Tăng Nhơn Phú, Hồ Chí Minh, Việt Nam</p>
                                    </div>
                                    <div class="d-flex gap-2 mb-2 align-items-center">
                                        <i class="fa-solid fa-phone text-muted small"></i>
                                        <p class="small text-muted mb-0">Hotline: 1900.5301</p>
                                    </div>
                                </div>
                                <a href="https://maps.app.goo.gl/Zbs56bVvcDaS9P948" target="_blank" class="btn btn-outline-danger w-100 mt-3 d-flex align-items-center justify-content-center gap-2">
                                    <i class="fa-solid fa-map-location-dot"></i>
                                    Xem trên Google Maps
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Branch 4 -->
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm overflow-hidden hover-float showroom-card">
                    <div class="row g-0 h-100">
                        <div class="col-md-5">
                            <div class="h-100 overflow-hidden">
                                <img src="https://images.unsplash.com/photo-1497215728101-856f4ea42174?q=80&w=1000&auto=format&fit=crop" class="w-100 h-100 object-fit-cover" alt="Showroom Long Thạnh Mỹ">
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="card-body p-4 d-flex flex-column h-100">
                                <div class="mb-auto">
                                    <h3 class="h5 fw-bold text-danger mb-3">Showroom SHTP (Long Thạnh Mỹ)</h3>
                                    <div class="d-flex gap-2 mb-3 align-items-start">
                                        <i class="fa-solid fa-location-dot text-muted mt-1"></i>
                                        <p class="small text-muted mb-0">Khu Công nghệ cao TP.HCM, Đường D1, P.Long Thạnh Mỹ, Tăng Nhơn Phú, Hồ Chí Minh, Việt Nam</p>
                                    </div>
                                    <div class="d-flex gap-2 mb-2 align-items-center">
                                        <i class="fa-solid fa-phone text-muted small"></i>
                                        <p class="small text-muted mb-0">Hotline: 1900.5301</p>
                                    </div>
                                </div>
                                <a href="https://maps.app.goo.gl/NHH3KsFmsTLFscfHA" target="_blank" class="btn btn-outline-danger w-100 mt-3 d-flex align-items-center justify-content-center gap-2">
                                    <i class="fa-solid fa-map-location-dot"></i>
                                    Xem trên Google Maps
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Why Choose PowerTech Section -->
        <div class="mt-5 pt-4 text-center">
            <h2 class="fw-800 mb-5">Tại sao nên đến Showroom PowerTech?</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="p-4 rounded-4 bg-white shadow-sm h-100">
                        <div class="feature-icon mb-3">
                            <i class="fa-solid fa-microchip fs-1 text-danger"></i>
                        </div>
                        <h4 class="h5 fw-bold mb-3">Trải nghiệm thực tế</h4>
                        <p class="small text-muted mb-0">Trực tiếp dùng thử các siêu phẩm PC, Laptop và linh kiện mới nhất từ các thương hiệu hàng đầu.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4 rounded-4 bg-white shadow-sm h-100">
                        <div class="feature-icon mb-3">
                            <i class="fa-solid fa-user-tie fs-1 text-danger"></i>
                        </div>
                        <h4 class="h5 fw-bold mb-3">Tư vấn chuyên nghiệp</h4>
                        <p class="small text-muted mb-0">Đội ngũ chuyên gia kỹ thuật hỗ trợ build máy theo nhu cầu và ngân sách của bạn.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4 rounded-4 bg-white shadow-sm h-100">
                        <div class="feature-icon mb-3">
                            <i class="fa-solid fa-screwdriver-wrench fs-1 text-danger"></i>
                        </div>
                        <h4 class="h5 fw-bold mb-3">Hỗ trợ kỹ thuật</h4>
                        <p class="small text-muted mb-0">Tiếp nhận bảo hành và hỗ trợ xử lý sự cố trực tiếp, nhanh chóng và tin cậy.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .showroom-page {
        background-color: #f8f9fa;
    }
    
    .hover-float {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .hover-float:hover {
        transform: translateY(-8px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,0.1) !important;
    }
    
    .tracking-tight {
        letter-spacing: -2px;
    }
    
    .fw-800 {
        font-weight: 800;
    }
    
    .showroom-card img {
        transition: transform 0.5s ease;
    }
    
    .showroom-card:hover img {
        transform: scale(1.1);
    }
    
    .feature-icon {
        width: 80px;
        height: 80px;
        background: #fff5f5;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

    .mt-n5 {
        margin-top: -3rem !important;
        position: relative;
        z-index: 5;
    }
</style>
