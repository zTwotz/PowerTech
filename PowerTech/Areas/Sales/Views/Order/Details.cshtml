@model PowerTech.Models.Entities.Order
@{
    Layout = "_SalesLayout";
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.OrderCode}";
}

<!-- Top Header Section -->
<div class="mb-4">
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0 small fw-bold text-uppercase" style="letter-spacing: 0.05em;">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Đơn hàng</a></li>
            <li class="breadcrumb-item active text-primary" aria-current="page">Chi tiết</li>
        </ol>
    </nav>
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <h1 class="h2 fw-800 mb-1 text-dark">Đơn hàng #@Model.OrderCode</h1>
            <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                <span class="badge-status @GetStatusClass(Model.OrderStatus)">
                    @GetStatusText(Model.OrderStatus)
                </span>
                <span class="badge-status @(Model.PaymentStatus == "Paid" ? "status-completed" : "status-pending")">
                    <i class="bi @(Model.PaymentStatus == "Paid" ? "bi-check-circle" : "bi-clock") me-1"></i> @(Model.PaymentStatus == "Paid" ? "Đã thanh toán" : "Chờ thanh toán")
                </span>
                <span class="badge-status status-neutral">
                    <i class="bi bi-wallet2 me-1"></i> @Model.PaymentMethod
                </span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-white border px-4 fw-bold shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
            <button class="btn btn-primary px-4 fw-bold shadow-sm">
                <i class="bi bi-printer me-2"></i> In hóa đơn
            </button>
        </div>
    </div>
</div>

<!-- Summary QuickView -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="summary-card shadow-sm border-0">
            <div class="summary-icon bg-info-subtle text-info">
                <i class="bi bi-currency-dollar"></i>
            </div>
            <div>
                <div class="text-muted small fw-bold text-uppercase">Tổng thanh toán</div>
                <div class="h4 fw-800 mb-0 text-dark">@Model.TotalAmount.ToString("N0")₫</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="summary-card shadow-sm border-0">
            <div class="summary-icon bg-success-subtle text-success">
                <i class="bi bi-box-seam"></i>
            </div>
            <div>
                <div class="text-muted small fw-bold text-uppercase">Số lượng SP</div>
                <div class="h4 fw-800 mb-0 text-dark">@Model.OrderItems.Sum(x => x.Quantity) sản phẩm</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="summary-card shadow-sm border-0">
            <div class="summary-icon bg-warning-subtle text-warning">
                <i class="bi bi-calendar3"></i>
            </div>
            <div>
                <div class="text-muted small fw-bold text-uppercase">Thời gian tạo</div>
                <div class="h4 fw-800 mb-0 text-dark">@Model.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Center Content -->
    <div class="col-lg-8">
        <!-- Products Table -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header border-0 bg-transparent py-4 ps-4">
                <h5 class="fw-800 mb-0 text-dark"><i class="bi bi-list-ul me-2 text-primary"></i>Danh sách sản phẩm</h5>
            </div>
            <div class="p-0">
                <div class="table-responsive">
                    <table class="table table-modern align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Sản phẩm</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end pe-4">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-light rounded-3 p-1" style="width: 54px; height: 54px;">
                                                <img src="@(string.IsNullOrEmpty(item.Product?.ThumbnailUrl) ? (string.IsNullOrEmpty(item.ProductImageSnapshot) ? "/images/no-image.png" : item.ProductImageSnapshot) : item.Product.ThumbnailUrl)" 
                                                     class="w-100 h-100 object-fit-contain rounded-2"/>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark lh-sm mb-1" style="font-size: 14px;">@item.ProductNameSnapshot</div>
                                                <div class="text-muted small fw-medium">SKU: <span class="bg-light px-2 rounded">@item.ProductSkuSnapshot</span></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end fw-semibold">@item.UnitPrice.ToString("N0")₫</td>
                                    <td class="text-center fw-bold text-secondary">@item.Quantity</td>
                                    <td class="text-end pe-4 fw-800 text-dark">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="bg-light p-4 rounded-bottom-4">
                <div class="row justify-content-end">
                    <div class="col-md-5">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted fw-bold small text-uppercase">Tạm tính:</span>
                            <span class="fw-bold text-dark">@Model.Subtotal.ToString("N0")₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted fw-bold small text-uppercase">Phí ship:</span>
                            <span class="fw-bold text-primary">+@Model.ShippingFee.ToString("N0")₫</span>
                        </div>
                        @if(Model.DiscountAmount > 0) {
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted fw-bold small text-uppercase">Giảm giá:</span>
                                <span class="fw-bold text-danger">-@Model.DiscountAmount.ToString("N0")₫</span>
                            </div>
                        }
                        <hr class="my-3 opacity-10">
                        <div class="d-flex justify-content-between">
                            <span class="h5 fw-800 mb-0 text-dark">TỔNG CỘNG:</span>
                            <span class="h4 fw-800 mb-0 text-primary">@Model.TotalAmount.ToString("N0")₫</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Info Grid (Customer & Shipping) -->
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header border-0 bg-transparent py-4 ps-4">
                        <h5 class="fw-800 mb-0 text-dark"><i class="bi bi-person-circle me-2 text-primary"></i>Khách hàng</h5>
                    </div>
                    <div class="card-body px-4 pt-0 pb-4">
                        <div class="d-flex align-items-center gap-3 mb-4 bg-light p-3 rounded-4">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 48px; height: 48px; font-size: 1.2rem;">
                                @(Model.User?.FullName?.Substring(0, 1).ToUpper() ?? "K")
                            </div>
                            <div>
                                <div class="fw-800 text-dark fs-5 lh-1">@Model.User?.FullName</div>
                                <div class="text-muted small">@Model.User?.Email</div>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="text-muted small fw-bold text-uppercase mb-1">Số điện thoại</div>
                                <div class="fw-bold text-dark small">@Model.PhoneNumber</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted small fw-bold text-uppercase mb-1">Ngày đăng ký</div>
                                <div class="fw-bold text-dark small">@(Model.User?.CreatedAt.ToString("dd/MM/yyyy") ?? "N/A")</div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <a href="#" class="btn btn-sm btn-outline-primary fw-bold w-100 rounded-3">Xem lịch sử mua hàng</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header border-0 bg-transparent py-4 ps-4">
                        <h5 class="fw-800 mb-0 text-dark"><i class="bi bi-truck me-2 text-primary"></i>Vận chuyển</h5>
                    </div>
                    <div class="card-body px-4 pt-0 pb-4">
                        <div class="mb-4">
                            <div class="text-muted small fw-bold text-uppercase mb-1">Người nhận</div>
                            <div class="fw-800 text-dark fs-5 lh-1">@Model.ReceiverName</div>
                        </div>
                        <hr class="opacity-5 my-3">
                        <div class="mb-3">
                            <div class="text-muted small fw-bold text-uppercase mb-1">Địa chỉ giao hàng</div>
                            <div class="text-dark fw-medium lh-sm">@Model.ShippingAddress</div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Note))
                        {
                            <div class="bg-warning bg-opacity-10 border border-warning border-opacity-25 p-3 rounded-3 mt-3">
                                <div class="text-warning small fw-bold text-uppercase mb-1 text-center"><i class="bi bi-chat-dots me-1"></i> Ghi chú người mua</div>
                                <div class="text-dark small lh-sm fw-medium italic text-center">"@Model.Note"</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Interaction Panel -->
    <div class="col-lg-4">
        <!-- Action Control Panel -->
        <div class="card border-0 shadow-sm mb-4 overflow-hidden">
            <div class="card-header border-0 bg-transparent py-4 ps-4">
                <h5 class="fw-800 mb-0 text-dark">Quy trình xử lý</h5>
            </div>
            <div class="card-body px-4 pt-0 pb-4">
                <!-- Shipper Payment Verification Card -->
                <div class="p-3 rounded-4 mb-4 @(Model.PaymentStatus == "Paid" ? "bg-success bg-opacity-10 border border-success border-opacity-25" : "bg-light border")">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="small fw-bold text-muted text-uppercase">Xác nhận thanh toán từ Shipper</span>
                        @if (Model.PaymentStatus == "Paid")
                        {
                            <span class="badge bg-success rounded-pill"><i class="bi bi-patch-check me-1"></i> ĐÃ THANH TOÁN</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary rounded-pill">CHƯA XÁC NHẬN</span>
                        }
                    </div>
                    @if (Model.PaymentStatus == "Paid")
                    {
                        <div class="text-success small fw-medium">
                            <i class="bi bi-check-circle-fill me-1"></i> Hệ thống/Shipper đã ghi nhận giao tiền thành công.
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> Đơn hàng đang chờ nhân viên giao hàng thu tiền.
                        </div>
                    }
                </div>

                <!-- Visual Stepper -->
                <div class="order-stepper mb-5 ps-2">
                    <div class="step-row completed">
                        <div class="step-indicator"><i class="bi bi-check-lg"></i></div>
                        <div class="step-label text-success">Đã đặt hàng</div>
                    </div>
                    <div class="step-row @(GetStepClass(Model.OrderStatus, "Processing"))">
                        <div class="step-indicator">@Html.Raw(GetStepIcon(Model.OrderStatus, "bi-gear-fill", "Processing"))</div>
                        <div class="step-label">Đang xử lý</div>
                    </div>
                    <div class="step-row @(GetStepClass(Model.OrderStatus, "Shipping", "Shipped"))">
                        <div class="step-indicator">@Html.Raw(GetStepIcon(Model.OrderStatus, "bi-truck", "Shipping", "Shipped"))</div>
                        <div class="step-label">Đang giao hàng</div>
                    </div>
                    <div class="step-row @(GetStepClass(Model.OrderStatus, "Completed"))">
                        <div class="step-indicator">@Html.Raw(GetStepIcon(Model.OrderStatus, "bi-check2-circle", "Completed"))</div>
                        <div class="step-label">Hoàn tất</div>
                    </div>
                </div>

                @{
                    var nextStatus = Model.OrderStatus switch {
                        "Pending" => "Processing",
                        "Processing" => "Shipping",
                        "Shipping" or "Shipped" => "Completed",
                        _ => ""
                    };

                    var btnText = nextStatus switch {
                        "Processing" => "XÁC NHẬN ĐƠN HÀNG",
                        "Shipping" => "XỬ LÝ XONG - GIAO HÀNG",
                        "Completed" => "XÁC NHẬN HOÀN TẤT",
                        _ => "ĐƠN HÀNG ĐÃ KẾT THÚC"
                    };

                    var btnColor = nextStatus switch {
                        "Processing" => "btn-primary",
                        "Shipping" => "btn-info text-white",
                        "Completed" => "btn-success",
                        _ => "btn-light disabled"
                    };

                    bool isCompleteLocked = nextStatus == "Completed";
                }

                @if (!string.IsNullOrEmpty(nextStatus))
                {
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        <input type="hidden" name="status" value="@nextStatus" />
                        
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-2">Ghi chú nội bộ</label>
                            <textarea name="internalNote" class="form-control border-0 shadow-sm rounded-4 p-3 bg-light" rows="2" placeholder="Ghi chú cập nhật...">@Model.InternalNote</textarea>
                        </div>

                        <button type="submit" class="btn @btnColor w-100 py-3 fw-800 rounded-4 shadow-sm @(isCompleteLocked ? "disabled opacity-50" : "hover-scale")" 
                                id="btnUpdateStatus" @(isCompleteLocked ? "disabled" : "")>
                            <i class="bi bi-arrow-right-circle-fill me-2"></i> @btnText
                        </button>
                        
                        @if (nextStatus == "Completed")
                        {
                            <div class="bg-warning bg-opacity-10 text-warning small mt-3 p-3 rounded-4 fw-bold text-center border border-warning border-opacity-25">
                                <i class="bi bi-shield-lock-fill me-1"></i> Đơn hàng đang gửi Shipper. Vui lòng chờ Shipper xác nhận giao hàng thành công trên ứng dụng để hoàn tất!
                            </div>
                        }
                    </form>
                }
                else if (Model.OrderStatus == "Completed")
                {
                    <div class="pt-success-card">
                        <div class="pt-success-icon">
                            <i class="bi bi-check-lg"></i>
                        </div>
                        <h4 class="fw-800 mb-1">HOÀN TẤT</h4>
                        <p class="small mb-0 opacity-75">Đơn hàng đã giao và thanh toán thành công.</p>
                    </div>
                }
                else if (Model.OrderStatus == "Cancelled")
                {
                    <div class="pt-danger-card">
                        <div class="pt-danger-icon">
                            <i class="bi bi-x-lg"></i>
                        </div>
                        <h4 class="fw-800 mb-1">ĐÃ HỦY</h4>
                        <p class="small mb-0 opacity-75">Đơn hàng đã bị hủy bỏ khỏi hệ thống.</p>
                    </div>
                }
            </div>
        </div>

        <!-- History Timeline -->
        @if (Model.OrderHistories != null && Model.OrderHistories.Any())
        {
            <div class="card border-0 shadow-sm border-top-primary">
                <div class="card-header border-0 bg-transparent py-4 ps-4">
                    <h5 class="fw-800 mb-0 text-dark"><i class="bi bi-clock-history me-2 text-primary"></i>Lịch sử xử lý</h5>
                </div>
                <div class="card-body px-4 pt-0 pb-4">
                    <div class="timeline-modern">
                        @foreach (var entry in Model.OrderHistories.OrderByDescending(h => h.CreatedAt))
                        {
                            <div class="timeline-item-modern @(entry == Model.OrderHistories.OrderByDescending(h => h.CreatedAt).First() ? "active" : "")">
                                <div class="timeline-time">@entry.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</div>
                                <div class="timeline-desc fw-bold text-dark">@entry.Action</div>
                                <div class="text-muted small">@entry.Note</div>
                                <div class="x-small text-primary fw-bold mt-1">Bởi: @entry.PerformedBy</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@functions {
    string GetStatusClass(string status) => status switch {
        "Pending" => "status-pending",
        "Processing" or "Confirmed" => "status-processing",
        "Shipping" or "Shipped" => "status-shipping",
        "Completed" => "status-completed",
        "Cancelled" => "status-cancelled",
        _ => "status-neutral"
    };

    string GetStatusText(string status) => status switch {
        "Pending" => "Chờ duyệt",
        "Processing" => "Đang xử lý",
        "Shipping" or "Shipped" => "Vận chuyển",
        "Completed" => "Hoàn tất",
        "Cancelled" => "Đã hủy",
        _ => status
    };

    string GetStepClass(string currentStatus, params string[] targets) {
        if (targets.Any(t => t == "Processing") && (new[]{"Processing", "Shipping", "Shipped", "Completed"}.Contains(currentStatus))) return "completed";
        if (targets.Any(t => t == "Shipping") && (new[]{"Shipping", "Shipped", "Completed"}.Contains(currentStatus))) return "completed";
        if (targets.Any(t => t == "Completed") && currentStatus == "Completed") return "completed";
        
        if (targets.Contains(currentStatus)) return "active";
        return "";
    }

    string GetStepIcon(string currentStatus, string iconClass, params string[] targets) {
        if (GetStepClass(currentStatus, targets) == "completed") return "<i class='bi bi-check-lg'></i>";
        return $"<i class='bi {iconClass}'></i>";
    }
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --pt-primary: #e30019;
            --pt-bg: #f8fafc;
        }

        .fw-800 { font-weight: 800; }
        .object-fit-contain { object-fit: contain; }
        .border-top-primary { border-top: 4px solid var(--pt-primary) !important; }

        /* Summary Cards */
        .summary-card {
            background: #fff;
            padding: 1.5rem;
            border-radius: 1.25rem;
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }
        .summary-icon {
            width: 52px;
            height: 52px;
            border-radius: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        /* Modern Table */
        .table-modern thead th {
            border: none;
            background: #f8fafc;
            color: #64748b;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            padding: 16px 12px;
        }
        .table-modern tbody td { padding: 16px 12px; border-bottom: 1px solid #f1f5f9; }

        /* Badges */
        .badge-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
        }
        .status-pending { background-color: #fef3c7; color: #92400e; }
        .status-processing { background-color: #dcfce7; color: #166534; }
        .status-shipping { background-color: #e0f2fe; color: #075985; }
        .status-completed { background-color: #dcfce7; color: #166534; }
        .status-cancelled { background-color: #fee2e2; color: #991b1b; }
        .status-neutral { background-color: #f1f5f9; color: #475569; }

        /* Order Stepper Vertical */
        .order-stepper { position: relative; }
        .step-row { position: relative; padding-bottom: 2.5rem; display: flex; align-items: center; gap: 1.25rem; }
        .step-row:last-child { padding-bottom: 0; }
        .step-row::after { content: ''; position: absolute; left: 17px; top: 35px; bottom: -5px; width: 2px; background: #e2e8f0; }
        .step-row:last-child::after { display: none; }
        .step-indicator { width: 36px; height: 36px; border-radius: 50%; background: #fff; border: 2px solid #e2e8f0; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; color: #94a3b8; position: relative; z-index: 2; }
        .step-label { font-weight: 700; color: #64748b; }
        
        .step-row.completed .step-indicator { background: #10b981; border-color: #10b981; color: #fff; }
        .step-row.completed .step-label { color: #059669; }
        .step-row.completed::after { background: #10b981; }

        .step-row.active .step-indicator { background: var(--pt-primary); border-color: var(--pt-primary); color: #fff; box-shadow: 0 0 0 4px rgba(227, 0, 25, 0.15); }
        .step-row.active .step-label { color: var(--pt-primary); }

        /* Timeline */
        .timeline-modern { position: relative; padding-left: 20px; }
        .timeline-item-modern { position: relative; padding-bottom: 1.5rem; border-left: 2px solid #f1f5f9; padding-left: 20px; }
        .timeline-item-modern:last-child { padding-bottom: 0; border-left: none; }
        .timeline-item-modern::before { content: ''; position: absolute; left: -7px; top: 3px; width: 12px; height: 12px; border-radius: 50%; background: #e2e8f0; border: 2px solid #fff; }
        .timeline-item-modern.active::before { background: var(--pt-primary); }
        .timeline-time { font-size: 11px; font-weight: 700; color: #94a3b8; margin-bottom: 2px; }
        .timeline-desc { font-size: 13px; line-height: 1.2; }
        .x-small { font-size: 0.7rem; }

        .hover-scale { transition: transform 0.2s; }
        .hover-scale:hover { transform: translateY(-2px); }

        /* Premium Cards */
        .pt-success-card {
            background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
            border: 1px solid rgba(16, 185, 129, 0.2);
            border-radius: 1.5rem;
            padding: 2.5rem 1.5rem;
            text-align: center;
            color: #065f46;
        }
        .pt-success-icon {
            width: 60px;
            height: 60px;
            background: #10b981;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 1.5rem;
            box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.4);
        }

        .pt-danger-card {
            background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 1.5rem;
            padding: 2.5rem 1.5rem;
            text-align: center;
            color: #991b1b;
        }
        .pt-danger-icon {
            width: 60px;
            height: 60px;
