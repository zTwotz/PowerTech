@{
    Layout = "_WarehouseLayout";
    ViewData["Title"] = "Lập phiếu nhập kho";
    var selected = ViewBag.SelectedProduct as PowerTech.Models.Entities.Product;
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-dark text-white p-4">
                <h5 class="mb-0 fw-bold"><i class="bi bi-box-arrow-in-down me-2 text-primary"></i> Phiếu Nhập Kho Mới</h5>
            </div>
            <div class="card-body p-4">
                @if (selected != null)
                {
                    <form asp-action="Create" method="post" id="stockForm">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-2">Sản phẩm cần thao tác</label>
                            <input type="hidden" name="productId" value="@selected.Id" id="productId" />
                            <div class="p-3 bg-light rounded-4 d-flex align-items-center mb-2 border-0 shadow-sm">
                                @if (!string.IsNullOrEmpty(selected.ThumbnailUrl))
                                {
                                    <img src="@selected.ThumbnailUrl" class="rounded-3 me-3 shadow-sm" style="width: 64px; height: 64px; object-fit: cover;" />
                                }
                                <div>
                                    <h6 class="fw-bold mb-0 text-dark">@selected.Name</h6>
                                    <div class="badge bg-secondary x-small mt-1">@selected.SKU</div>
                                </div>
                            </div>
                            <a asp-action="Index" class="btn btn-link btn-sm p-0 mb-3 text-muted text-decoration-none small">
                                <i class="bi bi-search me-1"></i> Tìm sản phẩm khác
                            </a>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted text-uppercase mb-2">Phân loại thao tác</label>
                                    <select name="referenceType" class="form-select border-light shadow-sm rounded-3">
                                        <option value="PurchaseReceipt">Nhập hàng (Mua mới)</option>
                                        <option value="Adjustment">Điều chỉnh kho (Thêm/Bớt)</option>
                                        <option value="Return">Khách trả hàng</option>
                                        <option value="Damaged">Hư hỏng/Mất mát (Xuất)</option>
                                        <option value="Other">Khác</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted text-uppercase mb-2">Số lượng (Nhập âm để xuất)</label>
                                    <div class="input-group">
                                        <input type="number" name="quantity" id="quantityInput" class="form-control border-light shadow-sm rounded-3" placeholder="Ví dụ: 10 hoặc -5" required />
                                        <span class="input-group-text bg-white border-light shadow-sm">đơn vị</span>
                                    </div>
                                    <div class="text-danger small mt-1">@Html.ValidationMessage("quantity")</div>
                                </div>
                            </div>
                        </div>

                        <!-- Visual Flow Preview -->
                        <div class="stock-preview mb-4 p-3 rounded-4 bg-dark text-white d-flex align-items-center justify-content-around shadow-sm">
                            <div class="text-center">
                                <div class="x-small opacity-50 mb-1">Tồn hiện tại</div>
                                <div class="fs-4 fw-bold" id="currentStock">@selected.StockQuantity</div>
                            </div>
                            <div class="fs-4 text-primary" id="arrowIcon"><i class="bi bi-arrow-right"></i></div>
                            <div class="text-center">
                                <div class="x-small opacity-50 mb-1">Dự kiến kho</div>
                                <div class="fs-4 fw-bold text-primary" id="afterStock">@selected.StockQuantity</div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-2">Ghi chú (Tùy chọn)</label>
                            <textarea name="note" class="form-control border-light shadow-sm rounded-3" rows="3" placeholder="Lý do nhập/xuất kho..."></textarea>
                        </div>

                        <div class="d-grid gap-3 d-sm-flex">
                            <a asp-action="Index" class="btn btn-light btn-lg px-4 flex-grow-1 rounded-pill small fw-bold">Hủy</a>
                            <button type="submit" class="btn btn-primary btn-lg px-4 flex-grow-1 rounded-pill fw-bold shadow-sm" id="btnSubmit">
                                <i class="bi bi-file-earmark-check me-1"></i> Xác nhận thao tác
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="mb-3">
                            <i class="bi bi-box-seam fs-1 text-muted opacity-25"></i>
                        </div>
                        <h6 class="fw-bold text-dark">Chưa chọn sản phẩm</h6>
                        <p class="text-muted small mb-4">Vui lòng quay lại danh sách hoặc sử dụng thanh tìm kiếm để chọn sản phẩm cần thao tác kho.</p>
                        <a asp-action="Index" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                            <i class="bi bi-search me-1"></i> Tìm kiếm sản phẩm
                        </a>
                    </div>
                }
            </div>
        </div>
        
        <!-- Quick Stats -->
        <div class="card border-0 shadow-sm rounded-4 mt-4 bg-primary bg-opacity-10 py-1">
            <div class="card-body p-4">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-info-circle-fill me-1"></i> Hướng dẫn nhập/xuất</h6>
                <ul class="small text-muted mb-0 ps-3">
                    <li class="mb-1"><strong>Nhập kho dương (+):</strong> Ghi số dương (VD: 10) khi nhập thêm hàng mới hoặc khách hàng trả lại.</li>
                    <li><strong>Xuất kho âm (-):</strong> Ghi số âm (VD: -5) khi hàng hóa bị hư hỏng, kiểm kê thiếu, hoặc dùng để xuất mẫu.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            function updatePreview() {
                var current = parseInt($('#currentStock').text()) || 0;
                var input = parseInt($('#quantityInput').val());
                if(isNaN(input)) input = 0;
                
                var after = current + input;
                $('#afterStock').text(after);
                
                // Update visuals based on negative/positive
                if (input < 0) {
                    $('#afterStock').removeClass('text-primary text-success').addClass('text-danger');
                    $('#arrowIcon').removeClass('text-primary text-success').addClass('text-danger');
                    $('#btnSubmit').removeClass('btn-primary btn-success').addClass('btn-danger').html('<i class="bi bi-box-arrow-right me-1"></i> Xác nhận xuất kho');
                } else if (input > 0) {
                    $('#afterStock').removeClass('text-primary text-danger').addClass('text-success');
                    $('#arrowIcon').removeClass('text-primary text-danger').addClass('text-success');
                    $('#btnSubmit').removeClass('btn-primary btn-danger').addClass('btn-success').html('<i class="bi bi-box-arrow-in-down me-1"></i> Xác nhận nhập kho');
                } else {
                    $('#afterStock').removeClass('text-success text-danger').addClass('text-primary');
                    $('#arrowIcon').removeClass('text-success text-danger').addClass('text-primary');
                    $('#btnSubmit').removeClass('btn-success btn-danger').addClass('btn-primary').html('<i class="bi bi-file-earmark-check me-1"></i> Xác nhận thao tác');
                }
                
                if (after < 0) {
                    $('#btnSubmit').prop('disabled', true);
                } else {
                    $('#btnSubmit').prop('disabled', false);
                }
            }

            $('#quantityInput').on('input', updatePreview);
        });
    </script>
}
