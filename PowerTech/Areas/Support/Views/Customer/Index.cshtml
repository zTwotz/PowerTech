@model IEnumerable<PowerTech.Models.Entities.ApplicationUser>
@{
    Layout = "_SupportLayout";
    ViewData["Title"] = "Chăm sóc khách hàng";
}

<div class="row align-items-center mb-4 pb-2">
    <div class="col-md-7">
        <h3 class="fw-800 text-dark mb-1">Tra cứu Khách hàng</h3>
        <p class="text-muted mb-0">Tìm kiếm thông tin khách hàng để hỗ trợ giải đáp đơn hàng và khiếu nại</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-10">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 rounded-start-pill ps-3">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" name="q" value="@ViewBag.SearchTerm" class="form-control border-start-0 rounded-end-pill py-2 shadow-none" placeholder="Nhập tên, email hoặc số điện thoại khách hàng...">
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold">Tìm kiếm</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0 table-modern">
                <thead>
                    <tr>
                        <th class="ps-4">Khách hàng</th>
                        <th>Liên hệ</th>
                        <th>Ngày gia nhập</th>
                        <th class="pe-4 text-end">Thành viên</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr class="cursor-pointer" onclick="window.location.href='@Url.Action("Detail", new { id = user.Id })'">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(user.FullName))&background=random" class="rounded-circle me-3" style="width: 40px; height: 40px;">
                                    <div>
                                        <div class="fw-bold text-dark">@user.FullName</div>
                                        <div class="text-muted x-small">ID: @user.Id.Substring(0, 8)...</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="small fw-bold">@user.Email</div>
                                <div class="text-muted x-small">@user.PhoneNumber</div>
                            </td>
                            <td>
                                <div class="small">@user.CreatedAt.ToString("dd/MM/yyyy")</div>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-action="Detail" asp-route-id="@user.Id" class="btn btn-action-view">
                                    Xem lịch sử <i class="bi bi-chevron-right ms-1"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="bi bi-person-exclamation fs-1 text-muted opacity-25"></i>
                                <p class="text-muted mt-2">Không tìm thấy khách hàng phù hợp</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .fw-800 { font-weight: 800; }
        .x-small { font-size: 0.75rem; }
        .cursor-pointer { cursor: pointer; }
        .cursor-pointer:hover { background-color: #f8fafc; }

        .table-modern thead th {
            border: none;
            background: #f8fafc;
            color: #64748b;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            padding: 16px 12px;
        }
        .table-modern tbody td {
            padding: 16px 12px;
            border-bottom: 1px solid #f1f5f9;
        }

        .btn-action-view {
            background-color: #fff;
            color: #0D6EFD;
            border: 1.5px solid #0D6EFD;
            border-radius: 20px;
            padding: 4px 16px;
            font-size: 12px;
            font-weight: 700;
            transition: all 0.2s;
        }
        .btn-action-view:hover {
            background-color: #0D6EFD;
            color: #fff;
        }
    </style>
}
