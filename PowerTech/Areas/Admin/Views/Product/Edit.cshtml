@model PowerTech.Areas.Admin.Models.ViewModels.ProductActionViewModel
@{
    ViewData["Title"] = $"Chỉnh sửa sản phẩm: {Model.Name}";
    var categories = ViewBag.Categories as List<PowerTech.Models.Entities.Category>;
    var brands = ViewBag.Brands as List<PowerTech.Models.Entities.Brand>;
}

<div class="admin-page-title">
    <div>
        <h1 class="h3 fw-800 mb-0">@ViewData["Title"]</h1>
        <p class="text-muted small mb-0">Cập nhật thông tin chi tiết và thuộc tính cho sản phẩm</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left me-2"></i> Quay lại</a>
    </div>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

    <div class="row g-4">
        <!-- Main Column -->
        <div class="col-lg-8">
            <!-- Basic Info Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="fw-bold mb-0">Thông tin cơ bản</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control text-primary fw-bold" placeholder="Laptop Gaming ASUS ROG..." onkeyup="generateSlug()" id="inputName"/>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SKU" class="form-label fw-bold">SKU <span class="text-danger">*</span></label>
                            <input asp-for="SKU" class="form-control" placeholder="PT-ASUS-ROG-01"/>
                            <span asp-validation-for="SKU" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Slug" class="form-label fw-bold">Slug (URL) <span class="text-danger">*</span></label>
                            <input asp-for="Slug" class="form-control" id="inputSlug" readonly/>
                            <span asp-validation-for="Slug" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="ShortDescription" class="form-label fw-bold">Mô tả ngắn</label>
                            <textarea asp-for="ShortDescription" class="form-control" rows="2" placeholder="Tóm tắt đặc điểm nổi bật..."></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control" rows="10" id="editor"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pricing & Inventory Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="fw-bold mb-0">Giá & Kho hàng</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label fw-bold">Giá niêm yết (Price) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Price" class="form-control fw-bold text-primary" type="number" step="1000"/>
                                <span class="input-group-text">₫</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DiscountPrice" class="form-label fw-bold">Giá khuyến mãi (để trống nếu không giảm)</label>
                            <div class="input-group">
                                <input asp-for="DiscountPrice" class="form-control" type="number" step="1000"/>
                                <span class="input-group-text">₫</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StockQuantity" class="form-label fw-bold">Số lượng trong kho</label>
                            <input asp-for="StockQuantity" class="form-control" type="number"/>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WarrantyMonths" class="form-label fw-bold">Thời gian bảo hành (tháng)</label>
                            <input asp-for="WarrantyMonths" class="form-control" type="number"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Column -->
        <div class="col-lg-4">
            <!-- Classification Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="fw-bold mb-0">Phân loại & Trạng thái</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" class="form-select">
                            <option value="">-- Chọn danh mục --</option>
                            @foreach (var c in categories ?? new())
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="BrandId" class="form-label fw-bold">Thương hiệu <span class="text-danger">*</span></label>
                        <select asp-for="BrandId" class="form-select">
                            <option value="">-- Chọn thương hiệu --</option>
                            @foreach (var b in brands ?? new())
                            {
                                <option value="@b.Id">@b.Name</option>
                            }
                        </select>
                        <span asp-validation-for="BrandId" class="text-danger small"></span>
                    </div>

                    <div class="form-check form-switch mb-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox">
                        <label class="form-check-label fw-bold" asp-for="IsActive">Hiển thị trên website</label>
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox">
                        <label class="form-check-label fw-bold" asp-for="IsFeatured">Sản phẩm Nổi bật (HOT)</label>
                    </div>
                </div>
            </div>

            <!-- Media Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="fw-bold mb-0">Hình ảnh sản phẩm</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <label class="fw-bold mb-2 d-block">Ảnh đại diện (Thumbnail) <span class="text-danger">*</span></label>
                    <div class="mb-3">
                        <img id="thumbPreview" src="@(string.IsNullOrEmpty(Model.ThumbnailUrl) ? "https://placehold.co/200x200?text=Preview" : Model.ThumbnailUrl)" 
                             class="img-fluid rounded border mb-2 shadow-sm" style="max-height: 200px;"/>
                        <input asp-for="ThumbnailImage" class="form-control" type="file" onchange="previewImage(this, 'thumbPreview')"/>
                        <p class="text-muted small mt-1">Hoặc nhập URL ảnh:</p>
                        <input asp-for="ThumbnailUrl" class="form-control form-control-sm" placeholder="https://..."/>
                    </div>

                    <hr/>
                    
                    <div class="mb-3">
                        <label class="fw-bold mb-2 d-block">Ảnh bổ sung hiện tại</label>
                        <div class="d-flex flex-wrap gap-2 justify-content-center">
                            @if (Model.ExistingImages != null && Model.ExistingImages.Any())
                            {
                                foreach (var img in Model.ExistingImages)
                                {
                                    <div class="position-relative">
                                        <img src="@img" class="rounded border" style="width: 60px; height: 60px; object-fit: contain;"/>
                                        @* <button type="button" class="btn btn-danger btn-sm rounded-circle position-absolute top-0 end-0 p-0" style="width: 18px; height: 18px; font-size: 10px;">×</button> *@
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted small italic">Chưa có ảnh mô tả</p>
                            }
                        </div>
                    </div>
                    
                    <label class="fw-bold mb-2 d-block">Thêm ảnh mới (Album)</label>
                    <input asp-for="MoreImages" class="form-control" type="file" multiple/>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="d-grid gap-2 sticky-bottom pb-4" style="z-index: 100;">
                <button type="submit" class="btn btn-primary btn-lg fw-bold text-uppercase py-3 rounded-3 shadow">
                    <i class="fa-solid fa-save me-2"></i> Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-light btn-lg fw-bold text-uppercase py-3 rounded-3 border">Hủy bỏ</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function generateSlug() {
            var name = document.getElementById('inputName').value;
            var slug = name.toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .replace(/[đĐ]/g, "d")
                .replace(/([^0-9a-z-\s])/g, "")
                .replace(/(\s+)/g, "-")
                .replace(/-+/g, "-")
                .replace(/^-+|-+$/g, "");
            document.getElementById('inputSlug').value = slug;
        }

        function previewImage(input, targetId) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#' + targetId).attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
