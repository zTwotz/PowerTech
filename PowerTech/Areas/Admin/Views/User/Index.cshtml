@using Microsoft.AspNetCore.Identity
@using PowerTech.Constants
@model IEnumerable<PowerTech.Models.Entities.ApplicationUser>
@{
    ViewData["Title"] = "Quản lý người dùng";
    var rolesDict = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}

<div class="admin-page-title">
    <div>
        <h1 class="h3 fw-800 mb-0">Quản lý người dùng</h1>
        <p class="text-muted small mb-0">Quản lý phân quyền và bảo mật tài khoản hệ thống</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light small text-muted text-uppercase">
                    <tr>
                        <th class="ps-4">Họ và tên</th>
                        <th>Email</th>
                        <th>Ngày tạo</th>
                        <th>Vai trò hiện tại</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        var isLocked = u.LockoutEnd != null && u.LockoutEnd > DateTime.Now;
                        var currentRole = rolesDict?[u.Id].FirstOrDefault() ?? "No Role";
                        
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@u.FullName</div>
                                @if(isLocked) { <span class="badge bg-danger rounded-pill x-small">Tài khoản bị khóa</span> }
                            </td>
                            <td>@u.Email</td>
                            <td class="small text-muted">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge @GetRoleBadge(currentRole) rounded-pill px-3">
                                    @currentRole
                                </span>
                            </td>
                            <td>
                                @if (isLocked)
                                {
                                    <span class="text-danger small"><i class="fa-solid fa-lock-open me-1"></i> Bị khóa</span>
                                }
                                else
                                {
                                    <span class="text-success small"><i class="fa-solid fa-check-circle me-1"></i> Đang hoạt động</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-primary" 
                                            onclick="openRoleModal('@u.Id', '@u.FullName', '@currentRole')" 
                                            title="Thay đổi quyền">
                                        <i class="fa-solid fa-user-shield"></i>
                                    </button>
                                    @if(u.Email != User.Identity?.Name) {
                                        <button class="btn btn-sm @(isLocked ? "btn-outline-success" : "btn-outline-danger")" 
                                                onclick="toggleLock('@u.Id', '@u.FullName')" 
                                                title="@(isLocked ? "Mở khóa" : "Khóa tài khoản")">
                                            <i class="fa-solid @(isLocked ? "fa-unlock" : "fa-user-lock")"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Role Modal -->
<div class="modal fade" id="roleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-bottom-0 pt-4 px-4 pb-0">
                <h5 class="modal-title fw-bold">Thay đổi vai trò người dùng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateRole" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="userId" id="modalUserId" />
                    <p class="text-muted small">Cập nhật quyền truy cập cho: <strong id="modalUserName" class="text-dark"></strong></p>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Chọn vai trò mới</label>
                        <select name="role" id="modalRole" class="form-select">
                            <option value="@UserRoles.Customer">@UserRoles.Customer (Mặc định)</option>
                            <option value="@UserRoles.Admin">@UserRoles.Admin</option>
                            <option value="@UserRoles.SalesStaff">@UserRoles.SalesStaff</option>
                            <option value="@UserRoles.WarehouseStaff">@UserRoles.WarehouseStaff</option>
                            <option value="@UserRoles.SupportStaff">@UserRoles.SupportStaff</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pb-4 px-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    string GetRoleBadge(string role)
    {
        return role switch
        {
            UserRoles.Admin => "bg-soft-danger text-danger",
            UserRoles.SalesStaff => "bg-soft-primary text-primary",
            UserRoles.WarehouseStaff => "bg-soft-warning text-warning",
            UserRoles.SupportStaff => "bg-soft-info text-info",
            _ => "bg-soft-secondary text-secondary"
        };
    }
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function openRoleModal(id, name, currentRole) {
            $('#modalUserId').val(id);
            $('#modalUserName').text(name);
            $('#modalRole').val(currentRole);
            new bootstrap.Modal(document.getElementById('roleModal')).show();
        }

        function toggleLock(id, name) {
            Swal.fire({
                title: 'Trạng thái tài khoản',
                text: `Bạn muốn thay đổi trạng thái khóa/mở cho ${name}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#D7262E',
                confirmButtonText: 'Đồng ý',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Admin/User/ToggleLock', { userId: id }, function(res) {
                        if (res.success) {
                            window.location.reload();
                        } else {
                            Swal.fire('Lỗi', 'Không thể cập nhật trạng thái!', 'error');
                        }
                    });
                }
            })
        }
    </script>
}
