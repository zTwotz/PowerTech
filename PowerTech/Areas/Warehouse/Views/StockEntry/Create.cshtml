@{
    Layout = "_WarehouseLayout";
    ViewData["Title"] = "Lập phiếu nhập kho";
    var selected = ViewBag.SelectedProduct as PowerTech.Models.Entities.Product;
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-dark text-white p-4">
                <h5 class="mb-0 fw-bold"><i class="bi bi-box-arrow-in-down me-2 text-primary"></i> Phiếu Nhập Kho Mới</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2">Sản phẩm cần nhập</label>
                        @if (selected != null)
                        {
                            <input type="hidden" name="productId" value="@selected.Id" />
                            <div class="p-3 bg-light rounded-3 d-flex align-items-center mb-2 border">
                                @if (!string.IsNullOrEmpty(selected.ThumbnailUrl))
                                {
                                    <img src="@selected.ThumbnailUrl" class="rounded-2 me-3 shadow-sm" style="width: 60px; height: 60px; object-fit: cover;" />
                                }
                                <div>
                                    <h6 class="fw-bold mb-0 text-dark">@selected.Name</h6>
                                    <small class="text-muted">SKU: @selected.SKU | Hiện có: <span class="fw-bold">@selected.StockQuantity</span></small>
                                </div>
                            </div>
                            <a asp-action="Create" asp-route-productId="" class="btn btn-link btn-sm p-0 mb-3 text-muted">Thay đổi sản phẩm</a>
                        }
                        else
                        {
                            <select name="productId" class="form-select form-select-lg rounded-3 border-dark border-opacity-25" id="productPicker">
                                <option value="">-- Chọn sản phẩm --</option>
                                @foreach (var prod in ViewBag.Products as IEnumerable<PowerTech.Models.Entities.Product>)
                                {
                                    <option value="@prod.Id">@prod.Name (@prod.SKU)</option>
                                }
                            </select>
                        }
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2">Số lượng nhập thêm</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white border-dark border-opacity-25 text-muted"><i class="bi bi-plus-lg"></i></span>
                            <input type="number" name="quantity" class="form-control border-dark border-opacity-25" placeholder="0" min="1" required />
                        </div>
                        <div class="text-danger small mt-1">@Html.ValidationMessage("quantity")</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2">Ghi chú nhập hàng</label>
                        <textarea name="note" class="form-control border-dark border-opacity-25 rounded-3" rows="3" placeholder="Ví dụ: Nhập hàng từ nhà cung cấp ABC..."></textarea>
                    </div>

                    <div class="d-flex gap-3">
                        <a asp-action="Index" asp-controller="Inventory" class="btn btn-outline-dark btn-lg px-4 flex-grow-1 rounded-3">Hủy</a>
                        <button type="submit" class="btn btn-primary btn-lg px-4 flex-grow-1 rounded-3 fw-bold shadow-sm">
                            <i class="bi bi-check2-circle me-1"></i> Hoàn tất nhập kho
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
        <!-- Quick Stats -->
        <div class="card border-0 shadow-sm rounded-4 mt-4 bg-primary bg-opacity-10 border-0">
            <div class="card-body p-4">
                <h6 class="fw-bold text-primary mb-3">📍 Hướng dẫn</h6>
                <p class="small text-muted mb-0">
                    Hệ thống sẽ cộng dồn số lượng nhập vào số lượng hiện có trong kho. 
                    Danh mục có thể tìm kiếm nhanh trong danh sách tồn kho trước khi bấm nhập.
                </p>
            </div>
        </div>
    </div>
</div>
