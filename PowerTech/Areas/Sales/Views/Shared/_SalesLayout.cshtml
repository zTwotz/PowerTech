@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4 min-vh-100 bg-light">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-lg-2 mb-4">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 100px;">
                <div class="card-body p-0">
                    <div class="p-3 border-bottom">
                        <h6 class="fw-bold mb-0 text-primary">SALES STAFF</h6>
                        <small class="text-muted">Bộ phận kinh doanh</small>
                    </div>
                    <div class="list-group list-group-flush rounded-bottom-4">
                        <a asp-area="Sales" asp-controller="Home" asp-action="Index" 
                           class="list-group-item list-group-item-action py-3 border-0 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "bg-primary text-white active fw-bold" : "")">
                            <i class="bi bi-speedometer2 me-2"></i> Tổng quan
                        </a>
                        <a asp-area="Sales" asp-controller="Order" asp-action="Index" 
                           class="list-group-item list-group-item-action py-3 border-0 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "bg-primary text-white active fw-bold" : "")">
                            <i class="bi bi-cart-check me-2"></i> Đơn hàng
                        </a>
                        <a asp-area="Sales" asp-controller="Order" asp-action="Pending" 
                           class="list-group-item list-group-item-action py-3 border-0">
                            <i class="bi bi-clock-history me-2"></i> Đơn mới
                        </a>
                    </div>
                    <div class="p-3 bg-light rounded-bottom-4">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">
                            <i class="bi bi-arrow-left me-1"></i> Về cửa hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-10">
            @RenderBody()
        </div>
    </div>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}
