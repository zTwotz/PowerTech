@model IEnumerable<PowerTech.Models.Entities.Order>
@{
    Layout = "_SalesLayout";
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white p-4 border-bottom">
        <div class="row align-items-center">
            <div class="col-md-4 text-start">
                <h5 class="mb-0 fw-bold">Danh sách đơn hàng</h5>
                <small class="text-muted">Quản lý và thực hiện các bước xử lý đơn hàng</small>
            </div>
            <div class="col-md-8 text-md-end mt-3 mt-md-0">
                <form asp-action="Index" method="get" class="d-inline-block">
                    <input type="hidden" name="status" value="@ViewBag.CurrentStatus" />
                    <div class="input-group input-group-sm rounded-pill border overflow-hidden shadow-sm d-inline-flex" style="max-width: 300px;">
                        <input type="text" name="searchTerm" class="form-control border-0 px-3" placeholder="Mã đơn, Tên, SĐT..." value="@ViewBag.SearchTerm" />
                        <button class="btn btn-white border-0 px-3" type="submit">
                            <i class="bi bi-search text-primary"></i>
                        </button>
                        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                        {
                            <a asp-action="Index" asp-route-status="@ViewBag.CurrentStatus" class="btn btn-white border-0 px-3 text-danger">
                                <i class="bi bi-x-lg"></i>
                            </a>
                        }
                    </div>
                </form>
                
                <div class="btn-group rounded-pill overflow-hidden border shadow-sm ms-2">
                    <a asp-action="Index" asp-route-status="" asp-route-searchTerm="@ViewBag.SearchTerm" class="btn btn-sm btn-@(string.IsNullOrEmpty(ViewBag.CurrentStatus) ? "primary" : "outline-primary border-0") px-3">Tất cả</a>
                    <a asp-action="Index" asp-route-status="Pending" asp-route-searchTerm="@ViewBag.SearchTerm" class="btn btn-sm btn-@(ViewBag.CurrentStatus == "Pending" ? "primary" : "outline-primary border-0") px-3">Mới</a>
                    <a asp-action="Index" asp-route-status="Processing" asp-route-searchTerm="@ViewBag.SearchTerm" class="btn btn-sm btn-@(ViewBag.CurrentStatus == "Processing" ? "primary" : "outline-primary border-0") px-3">Đang xử lý</a>
                    <a asp-action="Index" asp-route-status="Delivered" asp-route-searchTerm="@ViewBag.SearchTerm" class="btn btn-sm btn-@(ViewBag.CurrentStatus == "Delivered" ? "primary" : "outline-primary border-0") px-3">Hoàn tất</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày tạo</th>
                        <th>Tổng tiền</th>
                        <th>Thanh toán</th>
                        <th>Trạng thái</th>
                        <th class="pe-4 text-end">Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">
                                @order.OrderCode
                                @if (!string.IsNullOrEmpty(order.InternalNote))
                                {
                                    <i class="bi bi-clipboard-check text-success ms-1" title="Có ghi chú nội bộ"></i>
                                }
                            </td>
                            <td>
                                <div class="fw-medium">@order.ReceiverName</div>
                                <small class="text-muted">@order.PhoneNumber</small>
                            </td>
                            <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-bold text-primary">@order.TotalAmount.ToString("N0")₫</td>
                            <td>
                                <span class="badge rounded-pill bg-@(order.PaymentStatus switch {
                                    "Paid" => "success",
                                    "Unpaid" => "warning text-dark",
                                    _ => "secondary"
                                })">@order.PaymentStatus</span>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-@(order.OrderStatus switch {
                                    "Pending" => "warning text-dark",
                                    "Processing" => "primary",
                                    "Shipped" => "info",
                                    "Delivered" => "success",
                                    _ => "danger"
                                })">@order.OrderStatus</span>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-primary btn-sm rounded-3">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">Không tìm thấy đơn hàng nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
