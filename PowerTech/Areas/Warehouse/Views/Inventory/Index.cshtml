@model IEnumerable<PowerTech.Models.Entities.Product>
@{
    Layout = "_WarehouseLayout";
    ViewData["Title"] = "Quản lý tồn kho";
    var threshold = (int)ViewBag.LowStockThreshold;
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white p-4 border-bottom">
        <div class="row align-items-center">
            <div class="col-md-3 text-start">
                <h5 class="mb-0 fw-bold">Tồn kho</h5>
                <small class="text-muted">@Model.Count() sản phẩm</small>
            </div>
            <div class="col-md-9 text-md-end mt-3 mt-md-0">
                <form asp-action="Index" method="get" class="d-flex align-items-center justify-content-md-end gap-3 flex-wrap">
                    <input type="hidden" name="status" value="@ViewBag.Status" />
                    
                    <div class="input-group input-group-sm rounded-pill border overflow-hidden shadow-sm d-inline-flex flex-grow-1 position-relative" style="max-width: 600px; overflow: visible !important;">
                        <select name="categoryId" class="form-select border-0 px-3 bg-light" style="max-width: 160px; z-index: 2;" onchange="this.form.submit()">
                            <option value="">Tất cả</option>
                            @foreach (var cat in ViewBag.Categories)
                            {
                                <option value="@cat.Id" selected=@(cat.Id == (int?)ViewBag.CategoryId)>@cat.Name</option>
                            }
                        </select>
                        <div class="position-relative d-flex align-items-center flex-grow-1" style="z-index: 1;">
                            <i class="bi bi-search position-absolute start-0 ms-3 text-muted" style="z-index: 5;"></i>
                            <input type="text" id="inventorySearch" name="searchTerm" class="form-control border-0 ps-5" placeholder="Tìm sản phẩm, SKU, danh mục..." value="@ViewBag.SearchTerm" autocomplete="off" />
                        </div>
                        <button class="btn btn-dark border-0 px-4" type="submit" style="z-index: 2;">Tìm</button>

                        <!-- Real-time Results Dropdown -->
                        <div id="searchSuggestions" class="position-absolute w-100 shadow-lg rounded-4 border bg-white d-none overflow-hidden text-start" style="top: 100%; left: 0; margin-top: 10px; z-index: 1050;">
                            <div class="p-2 bg-light border-bottom d-flex justify-content-between align-items-center">
                                <span class="small fw-bold text-muted text-uppercase tracking-wider ps-2" style="font-size: 0.65rem;">Gợi ý sản phẩm</span>
                                <span id="resultCount" class="badge bg-primary rounded-pill me-2">0</span>
                            </div>
                            <div id="resultList" style="max-height: 350px; overflow-y: auto;">
                                <!-- Results will be injected here -->
                            </div>
                        </div>
                    </div>

                    <div class="btn-group btn-group-sm ms-2">
                        <a href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, categoryId = ViewBag.CategoryId })" 
                           class="btn @(string.IsNullOrEmpty(ViewBag.Status) ? "btn-dark" : "btn-outline-dark") rounded-start-pill px-3 fw-bold">
                            Tất cả
                        </a>
                        <a href="@Url.Action("Index", new { status = "low", searchTerm = ViewBag.SearchTerm, categoryId = ViewBag.CategoryId })" 
                           class="btn @(ViewBag.Status == "low" ? "btn-danger" : "btn-outline-danger") px-3 fw-bold">
                            <i class="bi bi-exclamation-triangle me-1"></i> Sắp hết
                        </a>
                        <a href="@Url.Action("Index", new { status = "out", searchTerm = ViewBag.SearchTerm, categoryId = ViewBag.CategoryId })" 
                           class="btn @(ViewBag.Status == "out" ? "btn-secondary text-white" : "btn-outline-secondary") rounded-end-pill px-3 fw-bold">
                            <i class="bi bi-x-circle me-1"></i> Đã hết
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Mã SKU</th>
                        <th>Danh mục</th>
                        <th>Giá bán</th>
                        <th class="text-center">Số lượng</th>
                        <th>Trạng thái</th>
                        <th class="pe-4 text-end">Cập nhật</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var prod in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(prod.ThumbnailUrl))
                                    {
                                        <img src="@prod.ThumbnailUrl" class="rounded-3 me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                                    }
                                    <div>
                                        <div class="fw-bold text-dark small mb-0">@prod.Name</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="text-muted small">@prod.SKU</span></td>
                            <td><span class="badge bg-light text-dark rounded-pill border">@prod.Category?.Name</span></td>
                            <td class="fw-bold">@prod.Price.ToString("N0")₫</td>
                            <td class="text-center">
                                <span class="fs-5 fw-bold @(prod.StockQuantity <= threshold ? "text-danger" : "text-dark")">@prod.StockQuantity</span>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-@(prod.StockQuantity == 0 ? "danger" : (prod.StockQuantity <= threshold ? "warning text-dark" : "success")) px-3">
                                    @(prod.StockQuantity == 0 ? "Hết hàng" : (prod.StockQuantity <= threshold ? "Sắp hết" : "Dồi dào"))
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-area="Warehouse" asp-controller="StockEntry" asp-action="Create" asp-route-productId="@prod.Id" class="btn btn-outline-dark btn-sm rounded-pill px-3">
                                    <i class="bi bi-plus-lg me-1"></i> Nhập kho
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">Không tìm thấy sản phẩm nào phù hợp yêu cầu</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            const $searchInput = $('#inventorySearch');
            const $suggestions = $('#searchSuggestions');
            const $resultList = $('#resultList');
            const $resultCount = $('#resultCount');
            let debounceTimer;

            $searchInput.on('input', function() {
                const query = $(this).val();
                clearTimeout(debounceTimer);

                if (query.length < 1) {
                    $suggestions.addClass('d-none');
                    return;
                }

                debounceTimer = setTimeout(() => {
                    $.get('@Url.Action("SearchProducts", "Inventory", new { area = "Warehouse" })', { searchTerm: query }, function(data) {
                        $resultList.empty();
                        
                        if (data && data.length > 0) {
                            $resultCount.text(data.length);
                            data.forEach(item => {
                                const html = `
                                    <a href="@Url.Action("Create", "StockEntry", new { area = "Warehouse" })?productId=${item.id}" 
                                       class="d-flex align-items-center p-2 text-decoration-none border-bottom search-item">
                                        <div class="flex-shrink-0">
                                            <img src="${item.thumbnailUrl || '/images/no-image.png'}" 
                                                 class="rounded-2 shadow-sm" 
                                                 style="width: 35px; height: 35px; object-fit: cover;">
                                        </div>
                                        <div class="flex-grow-1 ms-2 overflow-hidden">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <h6 class="mb-0 text-dark fw-bold text-truncate" style="font-size: 0.85rem;">${item.name}</h6>
                                                <span class="badge bg-light text-muted border extra-small ms-1" style="font-size: 0.6rem;">${item.sku}</span>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <small class="text-muted" style="font-size: 0.7rem;">${item.category}</small>
                                                <small class="fw-bold ${item.stockQuantity <= 10 ? 'text-danger' : 'text-primary'}" style="font-size: 0.75rem;">
                                                    Tồn: ${item.stockQuantity}
                                                </small>
                                            </div>
                                        </div>
                                    </a>
                                `;
                                $resultList.append(html);
                            });
                            $suggestions.removeClass('d-none');
                        } else {
                            $resultList.append('<div class="p-3 text-center text-muted small">Không tìm thấy sản phẩm</div>');
                            $resultCount.text(0);
                            $suggestions.removeClass('d-none');
                        }
                    });
                }, 300);
            });

            // Close suggestions when clicking outside
            $(document).on('click', function(e) {
                if (!$(e.target).closest('.position-relative').length) {
                    $suggestions.addClass('d-none');
                }
            });

            // Re-open suggestions if input focused and has value
            $searchInput.on('focus', function() {
                if ($(this).val().length > 0) {
                    $suggestions.removeClass('d-none');
                }
            });
        });
    </script>

    <style>
        .extra-small { padding: 2px 5px; }
        .search-item { transition: all 0.2s ease; }
        .search-item:hover { background-color: #f8f9fa; }
        
        #resultList::-webkit-scrollbar { width: 5px; }
        #resultList::-webkit-scrollbar-track { background: #f8f9fa; }
        #resultList::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 10px; }
        #resultList::-webkit-scrollbar-thumb:hover { background: #9ca3af; }

        #searchSuggestions {
            animation: slideDown 0.2s ease-out;
            box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
        }
        @@keyframes slideDown {
            from { opacity: 0; transform: translateY(-5px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
}
