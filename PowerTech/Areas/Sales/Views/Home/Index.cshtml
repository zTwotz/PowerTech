@{
    Layout = "_SalesLayout";
    ViewData["Title"] = "Sales Dashboard";
}

<div class="row g-4 mb-4">
    <!-- Stats Cards -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-warning text-dark bg-opacity-75">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0 bg-white bg-opacity-50 rounded-3 p-3">
                        <i class="bi bi-clock-history fs-3 text-warning"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-uppercase small fw-bold mb-1">Đơn hàng mới</h6>
                        <h2 class="mb-0">@ViewBag.Stats.PendingOrders</h2>
                    </div>
                </div>
                <div class="small fw-bold">Cần xử lý gấp</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary text-white bg-opacity-75">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0 bg-white bg-opacity-50 rounded-3 p-3">
                        <i class="bi bi-gear fs-3 text-primary"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-uppercase small fw-bold mb-1">Đang xử lý</h6>
                        <h2 class="mb-0">@ViewBag.Stats.ProcessingOrders</h2>
                    </div>
                </div>
                <div class="small fw-bold">Chờ đóng gói/giao</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-danger text-white bg-opacity-75">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0 bg-white bg-opacity-50 rounded-3 p-3">
                        <i class="bi bi-x-circle fs-3 text-danger"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-uppercase small fw-bold mb-1">Đơn bị hủy</h6>
                        <h2 class="mb-0">@ViewBag.Stats.CancelledOrders</h2>
                    </div>
                </div>
                <div class="small fw-bold">Đã hủy/thất bại</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white p-4 border-bottom d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">Đơn hàng gần đây</h5>
        <a asp-controller="Order" asp-action="Index" class="btn btn-primary btn-sm rounded-pill px-4">Xem tất cả</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày tạo</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="pe-4 text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in ViewBag.Stats.RecentOrders)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@order.OrderCode</td>
                            <td>
                                <div class="fw-medium">@order.ReceiverName</div>
                                <small class="text-muted">@order.User?.Email</small>
                            </td>
                            <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-bold text-primary">@order.TotalAmount.ToString("N0")₫</td>
                            <td>
                                <span class="badge rounded-pill bg-@(order.OrderStatus switch {
                                    "Pending" => "warning text-dark",
                                    "Processing" => "primary",
                                    "Shipped" => "info",
                                    "Delivered" => "success",
                                    _ => "danger"
                                })">@order.OrderStatus</span>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-primary btn-sm rounded-3">
                                    Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!((IEnumerable<dynamic>)ViewBag.Stats.RecentOrders).Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Chưa có đơn hàng nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
