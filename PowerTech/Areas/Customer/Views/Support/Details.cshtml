@model PowerTech.Models.Entities.SupportTicket
@{
    ViewData["Title"] = "Chi tiết yêu cầu #" + Model.TicketCode;
    Layout = "_CustomerLayout";
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-area="Store" asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Yêu cầu hỗ trợ</a></li>
        <li class="breadcrumb-item active" aria-current="page">#@Model.TicketCode</li>
    </ol>
</nav>

        <div class="row g-4">
            <div class="col-lg-8">
                <!-- Original Ticket Content -->
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                    <div class="card-header bg-white py-3 px-4 border-bottom border-light d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-circle-question text-primary me-2"></i>
                            <h2 class="h6 fw-bold mb-0">Nội dung yêu cầu</h2>
                        </div>
                        <span class="text-muted small">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="card-body p-4">
                        <h1 class="h4 fw-bold mb-3">@Model.Title</h1>
                        <div class="text-dark lh-base" style="white-space: pre-line;">@Model.Content</div>
                        @if (!string.IsNullOrEmpty(Model.AttachmentUrl))
                        {
                            <div class="mt-4 pt-3 border-top border-light">
                                <h6 class="fw-bold small text-muted mb-2"><i class="fa-solid fa-paperclip me-1"></i> Tệp đính kèm</h6>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var url in Model.AttachmentUrl.Split(';', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <a href="@url" target="_blank">
                                            <img src="@url" class="img-fluid rounded-3 border" style="max-height: 150px; object-fit: contain;" alt="Attachment" />
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Responses Section -->
                <div class="mb-4">
                    <h3 class="h6 fw-bold text-muted mb-3"><i class="fa-solid fa-comments me-2"></i>TRAO ĐỔI</h3>
                    
                    <div class="conversation-history">
                        @foreach (var response in Model.Responses.Where(r => !r.IsInternal))
                        {
                            <div class="card border-0 shadow-sm rounded-4 mb-3 @(response.UserId == Model.UserId ? "ms-auto bg-primary bg-opacity-10" : "bg-white")" style="max-width: 85%;">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="fw-bold small @(response.UserId == Model.UserId ? "text-primary" : "text-dark")">
                                            @(response.UserId == Model.UserId ? "Bạn" : (response.User?.FullName ?? "Nhân viên hỗ trợ"))
                                            @if (response.UserId != Model.UserId)
                                            {
                                                <span class="badge bg-primary rounded-pill ms-2" style="font-size: 10px;">Support</span>
                                            }
                                        </div>
                                        <span class="text-muted small" style="font-size: 11px;">@response.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                    <div class="text-dark small lh-base" style="white-space: pre-line;">@response.Message</div>
                                    @if (!string.IsNullOrEmpty(response.AttachmentUrl))
                                    {
                                        <div class="mt-2 text-center">
                                            <a href="@response.AttachmentUrl" target="_blank">
                                                <img src="@response.AttachmentUrl" class="img-fluid rounded border mt-2" style="max-height: 150px; object-fit: contain;" alt="Attachment" />
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (string.IsNullOrEmpty(Model.AssignedToUserId) && !Model.Responses.Any())
                        {
                            <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                                <div class="text-muted small">
                                    <i class="fa-solid fa-hourglass-half fa-spin me-2 text-warning"></i>
                                    Hệ thống đang tiếp nhận yêu cầu của bạn. Nhân viên hỗ trợ sẽ phản hồi trong thời gian sớm nhất.
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (Model.Status != "Closed" && Model.Status != "Resolved")
                {
                    <!-- Reply Form -->
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                        <div class="card-body p-4">
                            <h3 class="h6 fw-bold mb-3">Gửi phản hồi cho chúng tôi</h3>
                            <form asp-action="AddResponse" method="post" enctype="multipart/form-data">
                                <input type="hidden" name="ticketId" value="@Model.Id" />
                                <div class="mb-3">
                                    <textarea name="message" class="form-control border-2 rounded-3 shadow-none small mb-3" rows="3" placeholder="Nhập tin nhắn của bạn..." required></textarea>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <label for="attachment" class="btn btn-outline-secondary btn-sm rounded-pill px-3 m-0">
                                            <i class="fa-solid fa-paperclip me-1"></i> Đính kèm ảnh
                                        </label>
                                        <input type="file" id="attachment" name="attachment" class="d-none" accept="image/*">
                                        <span class="small text-muted ms-2" id="fileName"></span>
                                    </div>
                                    <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill fw-bold small">
                                        Gửi phản hồi <i class="fa-solid fa-paper-plane ms-2"></i>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                    
                    <script>
                        document.getElementById('attachment').addEventListener('change', function(e) {
                            var fileName = e.target.files[0] ? e.target.files[0].name : '';
                            document.getElementById('fileName').textContent = fileName;
                        });
                    </script>
                }
                
                @if ((Model.Status == "Closed" || Model.Status == "Resolved") && Model.Rating == null)
                {
                    <!-- CSAT Form -->
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 border-top border-warning border-4 bg-warning bg-opacity-10">
                        <div class="card-body p-4 text-center">
                            <h3 class="h5 fw-bold mb-2">Đánh giá chất lượng hỗ trợ</h3>
                            <p class="text-muted small mb-4">Vui lòng dành chút thời gian đánh giá mức độ hài lòng của bạn.</p>
                            
                            <form asp-action="RateTicket" method="post">
                                <input type="hidden" name="ticketId" value="@Model.Id" />
                                
                                <div class="rating-stars mb-4 fs-2 text-warning" style="direction: rtl; unicode-bidi: bidi-override;">
                                    <input type="radio" id="star5" name="rating" value="5" class="d-none" />
                                    <label for="star5" class="star" title="Rất hài lòng"><i class="fa-regular fa-star"></i></label>
                                    
                                    <input type="radio" id="star4" name="rating" value="4" class="d-none" />
                                    <label for="star4" class="star" title="Hài lòng"><i class="fa-regular fa-star"></i></label>
                                    
                                    <input type="radio" id="star3" name="rating" value="3" class="d-none" />
                                    <label for="star3" class="star" title="Bình thường"><i class="fa-regular fa-star"></i></label>
                                    
                                    <input type="radio" id="star2" name="rating" value="2" class="d-none" />
                                    <label for="star2" class="star" title="Không hài lòng"><i class="fa-regular fa-star"></i></label>
                                    
                                    <input type="radio" id="star1" name="rating" value="1" class="d-none" required />
                                    <label for="star1" class="star" title="Rất tệ"><i class="fa-regular fa-star"></i></label>
                                </div>

                                <div class="mb-3 text-start">
                                    <textarea name="feedback" class="form-control border bg-white rounded-3 shadow-none small" rows="2" placeholder="Góp ý thêm (không bắt buộc)"></textarea>
                                </div>
                                <button type="submit" class="btn btn-warning px-5 py-2 rounded-pill fw-bold shadow-sm">
                                    GỬI ĐÁNH GIÁ
                                </button>
                            </form>
                        </div>
                    </div>
                }
                else if (Model.Rating != null)
                {
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 bg-light text-center">
                        <div class="card-body p-4">
                            <h6 class="fw-bold text-success mb-2"><i class="fa-solid fa-circle-check me-2"></i> Đã đánh giá @Model.Rating/5 Sao</h6>
                            @if (!string.IsNullOrEmpty(Model.Feedback))
                            {
                                <div class="small text-muted italic">"@Model.Feedback"</div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 100px;">
                    <h3 class="h6 fw-bold mb-4 border-bottom pb-3 uppercase text-muted">Thông tin ticket</h3>
                    
                    <div class="mb-4">
                        <label class="small text-muted mb-1 d-block">Trạng thái:</label>
                        @switch (Model.Status)
                        {
                            case "Open":
                                <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2 rounded-pill w-100 fs-7">Mới</span>
                                break;
                            case "In Progress":
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-pill w-100 fs-7">Đang xử lý</span>
                                break;
                            case "Resolved":
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill w-100 fs-7">Đã xử lý</span>
                                break;
                            case "Closed":
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2 rounded-pill w-100 fs-7">Đã đóng</span>
                                break;
                        }
                    </div>

                    <div class="mb-4">
                        <label class="small text-muted mb-1 d-block">Vấn đề cần hỗ trợ:</label>
                        <div class="d-flex align-items-center text-primary fw-bold">
                            <i class="fa-solid fa-circle-info me-2"></i> @Model.Priority
                        </div>
                    </div>

                    @if (Model.Order != null)
                    {
                        <div class="mb-4">
                            <label class="small text-muted mb-1 d-block">Đơn hàng liên quan:</label>
                            <a href="#" class="text-decoration-none fw-bold text-dark d-block p-3 bg-light rounded-3 border">
                                <i class="fa-solid fa-box-open me-2 text-primary"></i> #@Model.Order.OrderCode
                            </a>
                        </div>
                    }

                    <div class="mt-4 pt-4 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 py-3 rounded-pill fw-bold border-2">
                            <i class="fa-solid fa-arrow-left me-2"></i> QUAY LẠI
                        </a>
                    </div>
                </div>
            </div>

<style>
    .fs-7 { font-size: 0.85rem; }
    .badge { letter-spacing: 0.5px; }
    .italic { font-style: italic; }
    
    .rating-stars label {
        cursor: pointer;
        display: inline-block;
        transition: color 0.2s;
    }
    .rating-stars label i.fa-solid { display: none; }
    
    .rating-stars input:checked ~ label i.fa-regular { display: none; }
    .rating-stars input:checked ~ label i.fa-solid { display: inline-block; }
    
    .rating-stars label:hover ~ label i.fa-regular,
    .rating-stars label:hover i.fa-regular { display: none; }
    
    .rating-stars label:hover ~ label i.fa-solid,
    .rating-stars label:hover i.fa-solid { display: inline-block; }
    
    .rating-stars input:checked ~ label,
    .rating-stars label:hover,
    .rating-stars label:hover ~ label {
        color: #ffc107 !important;
    }
    .rating-stars i.fa-solid { color: #ffc107; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const stars = document.querySelectorAll('.rating-stars label i');
        const labels = document.querySelectorAll('.rating-stars label');
        
        labels.forEach(label => {
            label.addEventListener('mouseover', function() {
                var val = parseInt(this.previousElementSibling.value);
                labels.forEach(l => {
                    var v = parseInt(l.previousElementSibling.value);
                    if(v <= val) {
                        l.innerHTML = '<i class="fa-solid fa-star"></i>';
                    } else {
                        l.innerHTML = '<i class="fa-regular fa-star"></i>';
                    }
                });
            });
        });
        
        document.querySelector('.rating-stars').addEventListener('mouseout', function() {
            var checked = document.querySelector('.rating-stars input:checked');
            var val = checked ? parseInt(checked.value) : 0;
            
            labels.forEach(l => {
                var v = parseInt(l.previousElementSibling.value);
                if(v <= val) {
                    l.innerHTML = '<i class="fa-solid fa-star"></i>';
                } else {
                    l.innerHTML = '<i class="fa-regular fa-star"></i>';
                }
            });
        });
        
        var rads = document.querySelectorAll('.rating-stars input');
        rads.forEach(rad => {
            rad.addEventListener('change', function() {
                var val = parseInt(this.value);
                labels.forEach(l => {
                    var v = parseInt(l.previousElementSibling.value);
                    if(v <= val) {
                        l.innerHTML = '<i class="fa-solid fa-star"></i>';
                    } else {
                        l.innerHTML = '<i class="fa-regular fa-star"></i>';
                    }
                });
            });
        });
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/supportHub")
            .build();

        connection.on("ReceiveTicketUpdate", function (ticketId, senderName, message) {
            // If the message is for this ticket
            if (ticketId == @Model.Id) {
                // We reload to see the new message, but ideally we'd just append it via DOM
                var toastEl = document.createElement('div');
                toastEl.className = 'toast align-items-center text-white bg-info border-0 mb-3';
                toastEl.setAttribute('role', 'alert');
                toastEl.setAttribute('aria-live', 'assertive');
                toastEl.setAttribute('aria-atomic', 'true');
                toastEl.innerHTML = `
                  <div class="d-flex">
                    <div class="toast-body">
                      <b>${senderName}</b> vừa gửi tin nhắn mới! Trang sẽ tự động tải lại...
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                  </div>
                `;
                
                let container = document.getElementById('toast-container');
                if(!container) {
                    container = document.createElement('div');
                    container.id = 'toast-container';
                    container.className = 'toast-container position-fixed bottom-0 end-0 p-3';
                    document.body.appendChild(container);
                }
                container.appendChild(toastEl);
                
                var toast = new bootstrap.Toast(toastEl);
                toast.show();

                setTimeout(() => window.location.reload(), 2000);
            }
        });

        connection.start().then(function () {
            connection.invoke("JoinTicketGroup", "@Model.Id").catch(function (err) {
                return console.error(err.toString());
            });
        }).catch(function (err) {
            return console.error(err.toString());
        });
    });
</script>
