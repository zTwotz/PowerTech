@using PowerTech.Helpers
@model PowerTech.Models.Entities.ApplicationUser
@{
    Layout = "_SupportLayout";
    ViewData["Title"] = $"Chi tiết khách hàng: {Model.FullName}";
    
    var orders = ViewBag.Orders as IEnumerable<PowerTech.Models.Entities.Order>;
    var tickets = ViewBag.Tickets as IEnumerable<PowerTech.Models.Entities.SupportTicket>;
    var addresses = ViewBag.Addresses as IEnumerable<PowerTech.Models.Entities.UserAddress>;
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
    </a>
</div>

<div class="row g-4">
    <!-- User Info Card -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 text-center p-4 h-100">
            <div class="mb-3 mt-2">
                <img src="https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(Model.FullName))&background=0D6EFD&color=fff&size=128" class="rounded-circle shadow-sm" style="width: 100px; height: 100px;">
            </div>
            <h4 class="fw-800 text-dark mb-1">@Model.FullName</h4>
            <p class="text-muted small mb-3">Thành viên từ @Model.CreatedAt.ToString("dd/MM/yyyy")</p>
            
            <div class="d-grid gap-2 text-start mt-2">
                <div class="p-3 bg-light rounded-3">
                    <div class="text-muted x-small fw-bold text-uppercase mb-1">Email liên hệ</div>
                    <div class="text-dark fw-bold">@Model.Email</div>
                </div>
                <div class="p-3 bg-light rounded-3">
                    <div class="text-muted x-small fw-bold text-uppercase mb-1">Số điện thoại</div>
                    <div class="text-dark fw-bold">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)</div>
                </div>
                <div class="p-3 bg-light rounded-3">
                    <div class="text-muted x-small fw-bold text-uppercase mb-1">Số dư Ví Power</div>
                    <div class="text-primary fw-bold fs-5">@Model.WalletBalance.ToString("N0")₫</div>
                </div>
                <div class="p-3 bg-light rounded-3 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted x-small fw-bold text-uppercase mb-1">Trạng thái</div>
                        <div class="text-dark fw-bold status-label">@(Model.IsActive ? "Đang hoạt động" : "Đã khóa")</div>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input toggle-user-status" type="checkbox" role="switch" data-id="@Model.Id" @(Model.IsActive ? "checked" : "")>
                    </div>
                </div>
            </div>

            @if (addresses != null && addresses.Any())
            {
                <div class="mt-4 text-start">
                    <h6 class="fw-800 text-dark small text-uppercase mb-3">Địa chỉ giao hàng</h6>
                    @foreach (var addr in addresses)
                    {
                        <div class="mb-3 p-2 border-start border-3 @(addr.IsDefault ? "border-primary" : "border-muted") ps-3">
                            <div class="small fw-bold">@addr.ReceiverName @(addr.IsDefault ? "(Mặc định)" : "")</div>
                            <div class="x-small text-muted">@addr.StreetAddress, @addr.Ward, @addr.District, @addr.Province</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Activity History -->
    <div class="col-lg-8">
        <ul class="nav nav-pills custom-pills mb-4 bg-white p-2 rounded-pill shadow-sm" id="customerTab" role="tablist">
            <li class="nav-item flex-fill" role="presentation">
                <button class="nav-link active w-100 rounded-pill fw-bold small py-2" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button" role="tab">
                    Lịch sử đơn hàng (@(orders?.Count() ?? 0))
                </button>
            </li>
            <li class="nav-item flex-fill" role="presentation">
                <button class="nav-link w-100 rounded-pill fw-bold small py-2" id="tickets-tab" data-bs-toggle="tab" data-bs-target="#tickets" type="button" role="tab">
                    Yêu cầu hỗ trợ (@(tickets?.Count() ?? 0))
                </button>
            </li>
        </ul>

        <div class="tab-content" id="customerTabContent">
            <!-- Orders Tab -->
            <div class="tab-pane fade show active" id="orders" role="tabpanel">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 table-modern">
                            <thead>
                                <tr>
                                    <th class="ps-4">Mã đơn</th>
                                    <th>Ngày đặt</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end pe-4">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (orders != null && orders.Any())
                                {
                                    foreach (var order in orders)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-primary">#@order.OrderCode</div>
                                            </td>
                                            <td>
                                                <div class="small">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                            </td>
                                            <td>
                                                <span class="badge @OrderHelper.GetStatusBadgeClass(order.OrderStatus) x-small rounded-pill px-2">
                                                    @OrderHelper.GetStatusDisplayName(order.OrderStatus)
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-flex justify-content-end align-items-center gap-2">
                                                    <span class="fw-bold text-dark me-2">@order.TotalAmount.ToString("N0")₫</span>
                                                    <a asp-area="Sales" asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 py-1 fw-bold tiny">Chi tiết</a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted fst-italic">Khách hàng chưa có đơn hàng nào</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Tickets Tab -->
            <div class="tab-pane fade" id="tickets" role="tabpanel">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 table-modern">
                            <thead>
                                <tr>
                                    <th class="ps-4">Mã Ticket</th>
                                    <th>Tiêu đề</th>
                                    <th>Ngày gửi</th>
                                    <th class="text-end pe-4">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (tickets != null && tickets.Any())
                                {
                                    foreach (var t in tickets)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold">@t.TicketCode</div>
                                            </td>
                                            <td>
                                                <div class="small text-truncate" style="max-width: 250px;">@t.Title</div>
                                            </td>
                                            <td>
                                                <div class="small">@t.CreatedAt.ToString("dd/MM/yyyy")</div>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-flex justify-content-end align-items-center gap-2">
                                                    <span class="badge @(t.Status == "Closed" ? "bg-secondary" : t.Status == "Open" ? "bg-info" : "bg-primary") x-small rounded-pill">
                                                        @t.Status
                                                    </span>
                                                    <a asp-controller="Ticket" asp-action="Details" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 py-1 fw-bold tiny">Mở Ticket</a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted fst-italic">Không có yêu cầu hỗ trợ nào</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .fw-800 { font-weight: 800; }
        .x-small { font-size: 0.75rem; }
        
        .custom-pills .nav-link {
            color: #64748b;
            background: transparent;
            transition: all 0.2s;
        }
        .custom-pills .nav-link.active {
            color: #fff;
            background-color: #0D6EFD;
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
        }

        .table-modern thead th {
            border: none;
            background: #f8fafc;
            color: #64748b;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            padding: 16px 12px;
        }
        .table-modern tbody td {
            padding: 16px 12px;
            border-bottom: 1px solid #f1f5f9;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            $('.toggle-user-status').change(function() {
                var userId = $(this).data('id');
                var isActive = $(this).is(':checked');
                var label = $('.status-label');
                
                $.ajax({
                    url: '@Url.Action("ToggleStatus")',
                    type: 'POST',
                    data: { 
                        id: userId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(res) {
                        if (res.success) {
                            label.text(res.isActive ? "Đang hoạt động" : "Đã khóa");
                            Swal.fire({
                                toast: true,
                                position: 'top-end',
                                icon: 'success',
                                title: 'Cập nhật trạng thái thành công',
                                showConfirmButton: false,
                                timer: 1500
                            });
                        } else {
                            // Revert checkbox if failed
                            $(this).prop('checked', !isActive);
                            Swal.fire('Lỗi', 'Không thể cập nhật trạng thái người dùng', 'error');
                        }
                    }.bind(this),
                    error: function() {
                        $(this).prop('checked', !isActive);
                        Swal.fire('Lỗi', 'Đã có lỗi xảy ra khi kết nối server', 'error');
                    }.bind(this)
                });
            });
        });
    </script>
}
