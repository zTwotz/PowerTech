@model IEnumerable<PowerTech.Models.Entities.Product>
@{
    Layout = "_WarehouseLayout";
    ViewData["Title"] = "Quản lý tồn kho";
    var threshold = (int)ViewBag.LowStockThreshold;
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white p-4 border-bottom">
        <div class="row align-items-center">
            <div class="col-md-4 text-start">
                <h5 class="mb-0 fw-bold">Danh mục tồn kho</h5>
                <small class="text-muted">Tổng cộng @Model.Count() sản phẩm đã tìm thấy</small>
            </div>
            <div class="col-md-8 text-md-end mt-3 mt-md-0">
                <form asp-action="Index" method="get" class="d-inline-block">
                    <div class="input-group input-group-sm rounded-pill border overflow-hidden shadow-sm d-inline-flex" style="max-width: 400px;">
                        <select name="categoryId" class="form-select border-0 px-3 bg-light" style="max-width: 150px;">
                            <option value="">Tất cả danh mục</option>
                            @foreach (var cat in ViewBag.Categories)
                            {
                                <option value="@cat.Id" selected=@(cat.Id == (int?)ViewBag.CategoryId)>@cat.Name</option>
                            }
                        </select>
                        <input type="text" name="searchTerm" class="form-control border-0 px-3" placeholder="Tên sản phẩm, SKU..." value="@ViewBag.SearchTerm" />
                        <button class="btn btn-dark border-0 px-3" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
                <a asp-action="LowStock" class="btn btn-sm btn-outline-danger rounded-pill px-3 ms-2 shadow-sm fw-bold">
                    <i class="bi bi-exclamation-triangle me-1"></i> Sắp hết hàng
                </a>
            </div>
        </div>
    </div>
    
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Mã SKU</th>
                        <th>Danh mục</th>
                        <th>Giá bán</th>
                        <th class="text-center">Số lượng</th>
                        <th>Trạng thái</th>
                        <th class="pe-4 text-end">Cập nhật</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var prod in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(prod.ThumbnailUrl))
                                    {
                                        <img src="@prod.ThumbnailUrl" class="rounded-3 me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                                    }
                                    <div>
                                        <div class="fw-bold text-dark small mb-0">@prod.Name</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="text-muted small">@prod.SKU</span></td>
                            <td><span class="badge bg-light text-dark rounded-pill border">@prod.Category?.Name</span></td>
                            <td class="fw-bold">@prod.Price.ToString("N0")₫</td>
                            <td class="text-center">
                                <span class="fs-5 fw-bold @(prod.StockQuantity <= threshold ? "text-danger" : "text-dark")">@prod.StockQuantity</span>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-@(prod.StockQuantity == 0 ? "danger" : (prod.StockQuantity <= threshold ? "warning text-dark" : "success")) px-3">
                                    @(prod.StockQuantity == 0 ? "Hết hàng" : (prod.StockQuantity <= threshold ? "Sắp hết" : "Dồi dào"))
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-area="Warehouse" asp-controller="StockEntry" asp-action="Create" asp-route-productId="@prod.Id" class="btn btn-outline-dark btn-sm rounded-pill px-3">
                                    <i class="bi bi-plus-lg me-1"></i> Nhập kho
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">Không tìm thấy sản phẩm nào phù hợp yêu cầu</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
