@model IEnumerable<PowerTech.Models.Entities.Review>
@{
    Layout = "_SupportLayout";
    ViewData["Title"] = "Duyệt đánh giá của khách hàng";
}

<!-- Page Header / Breadcrumbs -->
<div class="row align-items-center mb-4 pb-2">
    <div class="col-md-7">
        <h3 class="fw-800 text-dark mb-1">Duyệt đánh giá</h3>
        <p class="text-muted mb-0">Phê duyệt hoặc ẩn các bình luận từ khách hàng trên website</p>
    </div>
    <div class="col-md-5 mt-3 mt-md-0 d-flex justify-content-md-end align-items-center gap-2">
        <form asp-action="Index" method="get" class="position-relative d-none d-lg-block">
            <input type="text" name="q" value="@ViewBag.SearchTerm" class="form-control border-0 shadow-sm ps-4 pe-5 rounded-pill bg-white py-2" style="width: 250px; font-size: 13px;" placeholder="Tìm sản phẩm or user...">
            <button type="submit" class="btn p-0 position-absolute top-50 translate-middle-y end-0 me-3 border-0 bg-transparent">
                <i class="bi bi-search text-muted" style="font-size: 13px;"></i>
            </button>
        </form>
    </div>
</div>

<!-- Filters -->
<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Index" asp-route-approved="" class="btn btn-pill-filter @(ViewBag.Approved == null ? "active" : "")">
            <i class="bi bi-grid-fill me-1"></i> Tất cả
        </a>
        <a asp-action="Index" asp-route-approved="false" class="btn btn-pill-filter @(ViewBag.Approved == false ? "active" : "")">
            <i class="bi bi-hourglass-split me-1"></i> Chờ duyệt (@Model.Count(r => !r.IsApproved))
        </a>
        <a asp-action="Index" asp-route-approved="true" class="btn btn-pill-filter @(ViewBag.Approved == true ? "active" : "")">
            <i class="bi bi-patch-check-fill me-1"></i> Đã duyệt
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0 table-modern">
                <thead>
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Khách hàng</th>
                        <th>Nội dung đánh giá</th>
                        <th class="text-center">Rating</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="pe-4 text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var review in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark text-truncate d-block" style="max-width: 200px;" title="@review.Product?.Name">
                                    @review.Product?.Name
                                </div>
                                <div class="text-muted x-small">SKU: @review.Product?.SKU</div>
                            </td>
                            <td>
                                <div class="fw-bold small">@review.User?.FullName</div>
                                <div class="text-muted x-small">@review.User?.Email</div>
                            </td>
                            <td style="max-width: 350px;">
                                <div class="p-3 bg-light rounded-4 small border-0 position-relative">
                                    <i class="bi bi-quote text-primary opacity-25 position-absolute top-0 start-0 ms-1" style="font-size: 20px;"></i>
                                    <div class="ps-3 pe-2 py-1 text-dark" style="line-height: 1.5;">@review.Comment</div>
                                    @if (review.ReviewImages != null && review.ReviewImages.Any())
                                    {
                                        <div class="d-flex gap-2 mt-2">
                                            @foreach (var img in review.ReviewImages)
                                            {
                                                <a href="@img.ImageUrl" target="_blank">
                                                    <img src="@img.ImageUrl" class="rounded shadow-sm border" style="width: 50px; height: 50px; object-fit: cover;" />
                                                </a>
                                            }
                                        </div>
                                    }
                                    <div class="x-small text-muted mt-2 text-end fw-bold">Ngày: @review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="text-warning mb-1">
                                    @for(int i=0; i<5; i++) {
                                        <i class="bi bi-star@(i < review.Rating ? "-fill" : "") small"></i>
                                    }
                                </div>
                                <div class="fw-800 text-dark small">@review.Rating.0</div>
                            </td>
                            <td class="text-center">
                                <span class="badge-status @(review.IsApproved ? "status-completed" : "status-pending")">
                                    @(review.IsApproved ? "ĐÃ DUYỆT" : "CHỜ DUYỆT")
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    @if (!review.IsApproved)
                                    {
                                        <form asp-action="Approve" method="post">
                                            <input type="hidden" name="id" value="@review.Id" />
                                            <button type="submit" class="btn btn-action-view">
                                                Duyệt ngay
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa đánh giá này?')">
                                        <input type="hidden" name="id" value="@review.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm border-0 rounded-circle" style="width: 32px; height: 32px; padding: 0;" title="Xóa">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted fst-italic">Không tìm thấy đánh giá nào cần xử lý</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .fw-800 { font-weight: 800; }
        .x-small { font-size: 0.75rem; }
        
        /* Filter Pills */
        .btn-pill-filter {
            border: 1px solid #e2e8f0;
            background: #fff;
            color: #64748b;
            border-radius: 20px;
            padding: 6px 20px;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.2s;
        }
        .btn-pill-filter:hover, .btn-pill-filter.active {
            background: #0DCAF0;
            color: #fff;
            border-color: #0DCAF0;
            box-shadow: 0 4px 10px rgba(13, 202, 240, 0.2);
        }

        /* Table Style */
        .table-modern thead th {
            border: none;
            background: #f8fafc;
            color: #64748b;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            padding: 18px 12px;
        }
        .table-modern tbody td {
            padding: 20px 12px;
            border-bottom: 1px solid #f1f5f9;
        }

        /* Badges */
        .badge-status {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
        }
        .status-pending { background-color: #fef3c7; color: #92400e; }
        .status-completed { background-color: #dcfce7; color: #166534; }

        .btn-action-view {
            background-color: #fff;
            color: #0DCAF0;
            border: 1.5px solid #0DCAF0;
            border-radius: 20px;
            padding: 4px 16px;
            font-size: 12px;
            font-weight: 700;
            transition: all 0.2s;
        }
        .btn-action-view:hover {
            background-color: #0DCAF0;
            color: #fff;
        }
    </style>
}
