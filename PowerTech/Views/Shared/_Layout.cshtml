                                    <li><a class="dropdown-item py-2 px-3 rounded-2 small" asp-area="Customer" asp-controller="Order" asp-action="Index"><i class="fa-solid fa-box-open me-2 text-success"></i> Đơn hàng của tôi</a></li>
                                    <li><a class="dropdown-item py-2 px-3 rounded-2 small" asp-area="Customer" asp-controller="Support" asp-action="Index"><i class="fa-solid fa-headset me-2 text-info"></i> Gửi yêu cầu hỗ trợ</a></li>
                                    
                                    @if (User.IsInRole(UserRoles.Admin) || User.IsInRole(UserRoles.SalesStaff) || 
                                         User.IsInRole(UserRoles.WarehouseStaff) || User.IsInRole(UserRoles.SupportStaff) || 
                                         User.IsInRole(UserRoles.Shipper))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li class="px-3 py-1 small fw-bold text-muted text-uppercase" style="font-size: 10px;">Ban quản trị</li>
                                        @if (User.IsInRole(UserRoles.Admin))
                                        {
                                            <li><a class="dropdown-item py-2 px-3 rounded-2 small" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="fa-solid fa-gauge-high me-2 text-danger"></i> Hệ thống Admin</a></li>
                                        }
                                        @if (User.IsInRole(UserRoles.Admin) || User.IsInRole(UserRoles.SalesStaff))
                                        {
                                            <li><a class="dropdown-item py-2 px-3 rounded-2 small" asp-area="Sales" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-sack-dollar me-2 text-success"></i> Nghiệp vụ Sales</a></li>
                                        }
                                        @if (User.IsInRole(UserRoles.Admin) || User.IsInRole(UserRoles.WarehouseStaff))
                                        {
                                            <li><a class="dropdown-item py-2 px-3 rounded-2 small" asp-area="Warehouse" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-boxes-stacked me-2 text-warning"></i> Nghiệp vụ Kho</a></li>
                                        }
                                        @if (User.IsInRole(UserRoles.Admin) || User.IsInRole(UserRoles.SupportStaff))
                                        {
                                            <li><a class="dropdown-item py-2 px-3 rounded-2 small" asp-area="Support" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-headset me-2 text-info"></i> Nghiệp vụ Hỗ trợ</a></li>
                                        }
                                        @if (User.IsInRole(UserRoles.Admin) || User.IsInRole(UserRoles.Shipper))
                                        {
                                            <li><a class="dropdown-item py-2 px-3 rounded-2 small" asp-area="Shipper" asp-controller="Order" asp-action="Index"><i class="fa-solid fa-truck-fast me-2 text-primary"></i> Nghiệp vụ Shipper</a></li>
                                        }
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                                            <button type="submit" class="dropdown-item py-2 px-3 rounded-2 small text-danger border-0 bg-transparent w-100 text-start"><i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="header-action-item d-flex align-items-center gap-2 text-decoration-none text-white">
                                <i class="fa-solid fa-circle-user fs-3"></i>
                                <div class="d-flex flex-column text-start">
                                    <span class="lh-1" style="font-size: 11px;">Đăng</span>
                                    <span class="lh-1 fw-bold" style="font-size: 13px;">nhập</span>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </header>

        <!-- Utility White Sub-header -->
        <nav class="sub-header bg-white border-bottom py-2 shadow-sm d-none d-md-block">
            <div class="container overflow-hidden">
                <div class="d-flex justify-content-between align-items-center">
                    <a href="/Store/Product/Detail?slug=pc-gvn-amd-r5-5600x-vga-rx-7600" class="sub-nav-item"><i class="fa-solid fa-tag me-2 text-muted"></i> PC AMD Ryzen 5 chỉ từ 21 triệu</a>
                    <div class="vr mx-2 opacity-10"></div>
                    <a href="/Store/Product?categoryId=15&brandIds=System.Collections.Generic.List%601%5BSystem.Int32%5D" class="sub-nav-item"><i class="fa-solid fa-fire-flame-curved me-2 text-muted"></i> Hot Deal | Laptop</a>
                    <div class="vr mx-2 opacity-10"></div>
                    <a asp-area="Store" asp-controller="News" asp-action="Index" class="sub-nav-item"><i class="fa-solid fa-newspaper me-2 text-muted"></i> Tin tức</a>
                    <div class="vr mx-2 opacity-10"></div>
