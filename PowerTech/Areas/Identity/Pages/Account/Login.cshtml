@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-container">
    <div class="auth-card">
        <h1 class="auth-title">Chào mừng trở lại</h1>
        <p class="auth-subtitle">Đăng nhập để quản lý đơn hàng và nhận nhiều ưu đãi hơn</p>

        <section>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                
                <div class="checkbox mb-3 d-flex justify-content-between align-items-center">
                    <label asp-for="Input.RememberMe" class="form-label small">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        Ghi nhớ đăng nhập
                    </label>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="auth-link small">Quên mật khẩu?</a>
                </div>
                
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary mb-3">ĐĂNG NHẬP</button>
                </div>
                
                <div class="text-center">
                    <p class="text-muted small">
                        Bạn chưa có tài khoản? 
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">Đăng ký ngay</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
