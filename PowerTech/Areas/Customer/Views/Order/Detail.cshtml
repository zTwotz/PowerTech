@model PowerTech.Models.Entities.Order

@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.OrderCode}";
    Layout = "_CustomerLayout";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <h3 class="mb-0 fw-bold"><i class="fa-solid fa-receipt me-2 text-primary"></i> Chi tiết đơn hàng</h3>
</div>

<div class="mb-4 p-4 border rounded-3 bg-light">
    <div class="row gy-4">
        <div class="col-md-4">
            <div class="text-uppercase small fw-bold text-muted mb-2">Đơn hàng</div>
            <h5 class="fw-bold mb-1">#@Model.OrderCode</h5>
            <div class="text-muted small">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="col-md-4">
            <div class="text-uppercase small fw-bold text-muted mb-2">Trạng thái thanh toán</div>
            <h5 class="fw-bold mb-1">
                @if (Model.PaymentStatus == "Paid")
                {
                    <span class="text-success"><i class="fa-solid fa-circle-check me-1"></i> Đã thanh toán</span>
                }
                else
                {
                    <span class="text-warning"><i class="fa-solid fa-circle-exclamation me-1"></i> Chưa thanh toán</span>
                }
            </h5>
            <div class="text-muted small">@Model.PaymentMethod</div>
        </div>
        <div class="col-md-4">
            <div class="text-uppercase small fw-bold text-muted mb-2">Trạng thái vận chuyển</div>
            <h5 class="fw-bold mb-1">
                <span class="badge bg-primary rounded-pill px-3 py-2 fw-normal">@Model.OrderStatus</span>
            </h5>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm bg-white">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3 border-bottom pb-2">Người nhận hàng</h6>
                <div class="fw-bold text-dark mb-1">@Model.ReceiverName</div>
                <div class="text-muted small mb-1">@Model.PhoneNumber</div>
                <div class="text-muted small">@Model.ShippingAddress</div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm bg-white">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3 border-bottom pb-2">Ghi chú đơn hàng</h6>
                <p class="text-muted small mb-0">@(string.IsNullOrEmpty(Model.Note) ? "Không có ghi chú." : Model.Note)</p>
            </div>
        </div>
    </div>
</div>

<h6 class="fw-bold mb-3">Danh sách sản phẩm</h6>
<div class="card border-0 shadow-sm overflow-hidden mb-4">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="py-3 border-0 ps-4">Sản phẩm</th>
                    <th class="py-3 border-0 text-center">Số lượng</th>
                    <th class="py-3 border-0 text-end pe-4">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderItems)
                {
                    <tr>
                        <td class="py-3 ps-4">
                            <div class="d-flex align-items-center">
                                <img src="@(string.IsNullOrEmpty(item.ProductImageSnapshot) ? "/images/no-image.png" : item.ProductImageSnapshot)" class="rounded shadow-sm me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                                <div>
                                    <div class="fw-bold text-dark" style="font-size: 14px;">@item.ProductNameSnapshot</div>
                                    <div class="text-muted small" style="font-size: 12px;">SKU: @item.ProductSkuSnapshot</div>
                                    <div class="text-danger fw-bold" style="font-size: 13px;">@item.UnitPrice.ToString("N0")₫</div>
                                </div>
                            </div>
                        </td>
                        <td class="py-3 text-center text-dark fw-bold">x @item.Quantity</td>
                        <td class="py-3 text-end text-dark fw-bold pe-4">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="row justify-content-end">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tạm tính:</span>
                    <span class="text-dark fw-bold">@Model.Subtotal.ToString("N0")₫</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Phí vận chuyển:</span>
                    <span class="text-dark fw-bold">+ @Model.ShippingFee.ToString("N0")₫</span>
                </div>
                @if (Model.DiscountAmount > 0)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-success">Giảm giá:</span>
                        <span class="text-success fw-bold">- @Model.DiscountAmount.ToString("N0")₫</span>
                    </div>
                }
                <hr />
                <div class="d-flex justify-content-between">
                    <span class="fw-bold text-dark h5 mb-0">Tổng cộng:</span>
                    <span class="fw-bold text-danger h5 mb-0">@Model.TotalAmount.ToString("N0")₫</span>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.OrderStatus == "Pending")
{
    <div class="mt-5 pt-4 border-top text-end">
        <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn hàng này?')">
            <button type="submit" class="btn btn-outline-danger px-4 fw-bold">
                <i class="fa-solid fa-ban me-2"></i> Hủy đơn hàng
            </button>
        </form>
    </div>
}

<div class="mt-4">
    <a asp-action="Index" class="btn btn-link text-decoration-none text-muted fw-bold">
        <i class="fa-solid fa-arrow-left me-2"></i> Quay lại danh sách
    </a>
</div>

<style>
    .card {
        transition: all 0.2s;
    }
</style>
