@{
    ViewData["Title"] = "Bảng điều khiển kinh doanh";
}

<!-- Summary Row -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-white p-2">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="text-muted small fw-bold">DOANH THU HÔM NAY</span>
                    <i class="bi bi-wallet2 text-primary"></i>
                </div>
                <h3 class="fw-bold mb-0">@ViewBag.Stats.RevenueToday.ToString("N0")₫</h3>
                <small class="text-success fw-medium">Thanh toán tại quầy</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-white p-2">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="text-muted small fw-bold">CHỜ XỬ LÝ</span>
                    <i class="bi bi-clock-history text-warning"></i>
                </div>
                <h3 class="fw-bold mb-0">@ViewBag.Stats.PendingOrders</h3>
                <small class="text-warning fw-medium">Đơn hàng mới chưa duyệt</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-white p-2">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="text-muted small fw-bold">ĐANG VẬN CHUYỂN</span>
                    <i class="bi bi-truck text-info"></i>
                </div>
                <h3 class="fw-bold mb-0">@ViewBag.Stats.ShippedOrders</h3>
                <small class="text-info fw-medium">Đang đến tay khách</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-white p-2">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="text-muted small fw-bold">HOÀN TẤT THÁNG</span>
                    <i class="bi bi-check-circle text-success"></i>
                </div>
                <h3 class="fw-bold mb-0">@ViewBag.Stats.CompletedOrdersMonth</h3>
                <small class="text-success fw-medium">Giao hàng thành công</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Orders -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white p-4 border-bottom d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Đơn hàng gần đây</h5>
                <a asp-controller="Order" asp-action="Index" class="btn btn-outline-primary btn-sm rounded-pill px-4">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4">Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Ngày tạo</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th class="pe-4 text-end">Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in (IEnumerable<dynamic>)ViewBag.Stats.RecentOrders)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@order.OrderCode</td>
                                    <td>
                                        <div class="fw-medium">@order.ReceiverName</div>
                                        <small class="text-muted">@order.PhoneNumber</small>
                                    </td>
                                    <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="fw-bold text-dark">@order.TotalAmount.ToString("N0")₫</td>
                                    <td>
                                        <span class="badge rounded-pill bg-@(order.OrderStatus switch {
                                            "Pending" => "warning text-dark",
                                            "Processing" or "Confirmed" => "primary",
                                            "Shipped" => "info",
                                            "Delivered" => "success",
                                            _ => "danger"
                                        })">@order.OrderStatus</span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn btn-light btn-sm rounded-circle p-2">
                                            <i class="bi bi-chevron-right px-1"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Products -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white p-4 border-bottom">
                <h5 class="mb-0 fw-bold">Sản phẩm bán chạy</h5>
            </div>
            <div class="card-body p-4">
                @foreach (var p in (IEnumerable<dynamic>)ViewBag.Stats.TopProducts)
                {
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-medium text-truncate" style="max-width: 200px;">@p.Name</span>
                            <span class="badge bg-light text-primary">@p.Quantity sản phẩm</span>
                        </div>
                        <div class="progress rounded-pill" style="height: 6px;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: @(Math.Min(100, (int)p.Quantity * 10))%"></div>
                        </div>
                        <div class="text-end small text-muted mt-1">@p.Revenue.ToString("N0")₫</div>
                    </div>
                }
                @if (!((IEnumerable<dynamic>)ViewBag.Stats.TopProducts).Any())
                {
                    <div class="text-center py-5 text-muted fst-italic">Chưa có dữ liệu bán hàng</div>
                }
            </div>
        </div>
    </div>
</div>
