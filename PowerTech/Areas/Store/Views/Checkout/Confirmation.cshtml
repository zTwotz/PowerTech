@model PowerTech.Models.Entities.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container my-5 text-center">
    <!-- Success Icon & Message -->
    <div class="mb-5">
        <div class="display-1 text-success mb-3">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        @if (Model.PaymentMethod == "COD")
        {
            <h1 class="h2 fw-bold">Đơn hàng đã được gửi, vui lòng chờ xác nhận!</h1>
            <p class="text-muted fs-5">Nhân viên bán hàng sẽ sớm liên hệ để xác nhận đơn hàng của bạn.</p>
        }
        else
        {
            <h1 class="h2 fw-bold">Cảm ơn bạn đã đặt hàng!</h1>
            <p class="text-muted fs-5">Đơn hàng của bạn đã được tiếp nhận và đang được xử lý.</p>
        }
        <div class="d-inline-block bg-light-danger border border-primary px-4 py-3 rounded-pill mt-3">
            <span class="fw-bold">Mã đơn hàng: </span>
            <span class="text-primary fw-800 fs-4 ms-2">@Model.OrderCode</span>
        </div>
    </div>

    <div class="row g-4 justify-content-center text-start">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 overflow-hidden">
                <h3 class="h5 fw-bold mb-4 border-bottom pb-3">Chi tiết đơn hàng</h3>
                
                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <div class="text-muted small mb-1"><i class="fa-solid fa-user me-1"></i> Người nhận</div>
                        <div class="fw-bold">@Model.ReceiverName</div>
                        <div class="small">@Model.PhoneNumber</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="text-muted small mb-1"><i class="fa-solid fa-location-dot me-1"></i> Địa chỉ giao hàng</div>
                        <div class="small fw-medium">@Model.ShippingAddress</div>
                    </div>
                </div>

                <div class="table-responsive mb-4">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr class="text-muted small text-uppercase">
                                <th>Sản phẩm</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded border p-1" style="width: 40px; height: 40px;">
                                                <img src="@item.ProductImageSnapshot" class="w-100 h-100 object-fit-contain">
                                            </div>
                                            <span class="small fw-bold text-truncate" style="max-width: 300px;">@item.ProductNameSnapshot</span>
                                        </div>
                                    </td>
                                    <td class="text-center small">@item.Quantity</td>
                                    <td class="text-end small fw-bold">@item.LineTotal.ToString("N0")₫</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="2" class="text-end fw-bold pt-3 pe-3">Tổng cộng:</td>
                                <td class="text-end fw-bold pt-3 fs-5 text-primary">@Model.TotalAmount.ToString("N0")₫</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                @if (Model.PaymentMethod == "Bank Transfer")
                {
                    <div class="alert alert-info border-info rounded-4 p-4">
                        <h4 class="h6 fw-bold mb-3"><i class="fa-solid fa-university me-2"></i>Thông tin chuyển khoản</h4>
                        <div class="row g-3 fs-6">
                            <div class="col-6 text-muted">Ngân hàng:</div>
                            <div class="col-6 fw-bold">Vietcombank - Chi nhánh TP.HCM</div>
                            <div class="col-6 text-muted">Số tài khoản:</div>
                            <div class="col-6 fw-bold">0123 4567 8999</div>
                            <div class="col-6 text-muted">Chủ tài khoản:</div>
                            <div class="col-6 fw-bold text-uppercase">CÔNG TY TNHH POWERTECH</div>
                            <div class="col-6 text-muted">Nội dung CK:</div>
                            <div class="col-6 fw-bold p-2 bg-white rounded border border-info">@Model.OrderCode</div>
                        </div>
                        <div class="mt-3 small text-muted">
                            <i class="fa-solid fa-triangle-exclamation me-1"></i> Vui lòng chuyển khoản đúng số tiền và nội dung để hệ thống tự động xác nhận nhanh nhất.
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning border-warning rounded-4 p-4">
                        <h4 class="h6 fw-bold mb-2"><i class="fa-solid fa-box-open me-2"></i>Thanh toán khi nhận hàng</h4>
                        <p class="mb-0 small">Vui lòng chuẩn bị số tiền <strong>@Model.TotalAmount.ToString("N0")₫</strong> để thanh toán cho shipper khi nhận được hàng.</p>
                    </div>
                }

                <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-5">
                    <a asp-area="Store" asp-controller="Home" asp-action="Index" class="btn btn-outline-soft rounded-pill px-5 py-3 fw-bold text-dark me-md-2">TIẾP TỤC MUA SẮM</a>
                    <a asp-area="Customer" asp-controller="Order" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-3 fw-bold">QUẢN LÝ ĐƠN HÀNG</a>
                </div>
            </div>
        </div>
    </div>
</div>


